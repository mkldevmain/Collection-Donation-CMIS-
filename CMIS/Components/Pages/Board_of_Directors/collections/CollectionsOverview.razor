@page "/board-of-directors/collections"
@using MudBlazor
@inject NavigationManager Nav
@layout CMIS.Components.Layout.DashboardLayout
@rendermode InteractiveServer

<PageTitle>Collection and Donation — CMIS Portal</PageTitle>

<div class="collection-root">
    <!-- PAGE HEADING -->
    <div class="page-heading">
        <h1 class="page-title">Collection and Donation</h1>
        <p class="page-subtitle">Manage tithes, offerings, recurring donations, and church expenses.</p>
    </div>


    <!-- AUTHORITY BANNER -->
    <div class="authority-banner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>Your authority: <strong>Monitor and audit</strong> district-wide collections. Financial data shown is automatically finalized upon submission by local ministries.</span>
    </div>

    <!-- SUMMARY CARDS -->
    <div class="summary-cards">
        <div class="summary-card">
            <div class="sc-icon sc-icon-tithes">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Medium" />
            </div>
            <div class="sc-info">
                <span class="sc-label">TOTAL DONATIONS</span>
                <span class="sc-value">₱@_totalDonations.ToString("N0")</span>
                <span class="sc-trend trend-up">+5.2% this month</span>
            </div>
        </div>

        <div class="summary-card">
            <div class="sc-icon sc-icon-offerings">
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Medium" />
            </div>
            <div class="sc-info">
                <span class="sc-label">TOTAL OFFERINGS</span>
                <span class="sc-value">₱@_totalOfferings.ToString("N0")</span>
                <span class="sc-trend trend-up">+8.3% this month</span>
            </div>
        </div>

        <div class="summary-card">
            <div class="sc-icon sc-icon-expenses">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Medium" />
            </div>
            <div class="sc-info">
                <span class="sc-label">TOTAL TITHES</span>
                <span class="sc-value">₱@_totalTithes.ToString("N0")</span>
                <span class="sc-trend trend-down">-1.5% this month</span>
            </div>
        </div>

        <div class="summary-card">
            <div class="sc-icon sc-icon-balance">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Medium" />
            </div>
            <div class="sc-info">
                <span class="sc-label">OVERALL COLLECTIONS</span>
                <span class="sc-value net-positive">₱@_totalOverallCollections.ToString("N0")</span>
                <span class="sc-trend trend-up">Healthy</span>
            </div>
        </div>
    </div>

    <!-- LOCAL CHURCHES CARDS -->
    <div class="recurring-header">
        <h2 class="form-title">Local Churches Breakdowns</h2>
    </div>

    <div class="recurring-cards">
        @foreach (var church in _localChurches)
        {
            <div class="recurring-card">
                <div class="rc-top">
                    <div class="rc-member">@church.Name</div>
                    <span class="status-badge status-active">
                        <span class="status-dot"></span>Active
                    </span>
                </div>
                
                <div class="rc-details">
                    <div class="rc-detail">
                        <span class="rc-label">Donations</span>
                        <span class="rc-value">₱@church.Donations.ToString("N0")</span>
                    </div>
                    <div class="rc-detail">
                        <span class="rc-label">Offerings</span>
                        <span class="rc-value">₱@church.Offerings.ToString("N0")</span>
                    </div>
                    <div class="rc-detail">
                        <span class="rc-label">Tithes</span>
                        <span class="rc-value">₱@church.Tithes.ToString("N0")</span>
                    </div>
                    <div class="rc-detail mt-1">
                        <span class="rc-label">Overall Total</span>
                        <span class="rc-value" style="color: #0d6efd; font-weight:700;">₱@church.OverallTotal.ToString("N0")</span>
                    </div>
                </div>

                <div class="rc-actions">
                    <button class="btn-secondary" @onclick="() => RequestCollection(church)" disabled="@church.HasRequestedCollection" style="@(church.HasRequestedCollection ? "opacity: 0.6;" : "")">
                        @(church.HasRequestedCollection ? "Requested" : "Request Collection")
                    </button>
                    <button class="btn-primary" @onclick='() => Nav.NavigateTo($"/board-of-directors/collections/{church.Id}")'>View Details</button>
                </div>
            </div>
        }
    </div>
</div>



<style>
.btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: #6b7c93;
    background: #f0f4f8;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
}
.btn-secondary:hover {
    background: #e2e8f0;
    color: #0d2137;
}
.collection-root {
    padding: 0 1rem;
}

.page-heading {
    margin-bottom: 1.5rem;
}

.page-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.65rem;
    color: #0d2137;
    margin: 0 0 0.3rem;
}

.page-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    color: #6b7c93;
    margin: 0;
}



.authority-banner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: #fef9e7;
    border: 1px solid #f9e79f;
    border-radius: 10px;
    margin-bottom: 1.25rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #7d6608;
}

.authority-banner svg {
    flex-shrink: 0;
    color: #d4ac0d;
}

.summary-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.summary-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #ffffff;
    border: 1px solid #e8ecf1;
    border-radius: 12px;
    padding: 1.15rem 1.25rem;
    transition: box-shadow 0.25s, transform 0.2s;
}

.summary-card:hover {
    box-shadow: 0 6px 20px rgba(13, 33, 55, 0.08);
    transform: translateY(-2px);
}

.sc-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.sc-icon-tithes    { background: #eaf2f8; color: #1a5276; }
.sc-icon-offerings { background: #fef5e7; color: #d4ac0d; }
.sc-icon-expenses  { background: #fdedec; color: #c0392b; }
.sc-icon-balance   { background: #eafaf1; color: #1e8449; }

.sc-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
}

.sc-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: #8e99a4;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.sc-value {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    color: #0d2137;
    white-space: nowrap;
}

.sc-value.net-positive { color: #1e8449; }

.sc-trend {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
}

.trend-up   { color: #27ae60; }
.trend-down { color: #c0392b; }

.recurring-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
}

.form-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    color: #0d2137;
    margin: 0;
}

.recurring-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.recurring-card {
    background: #ffffff;
    border: 1.5px solid #e8ecf1;
    border-radius: 12px;
    padding: 1.25rem;
    transition: box-shadow 0.25s, border-color 0.2s;
}

.recurring-card:hover {
    border-color: #1a5276;
    box-shadow: 0 4px 16px rgba(13, 33, 55, 0.08);
}

.rc-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.rc-member {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #0d2137;
}

.rc-details { display: flex; flex-direction: column; gap: 0.55rem; }

.rc-detail {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.rc-label { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #8e99a4; }
.rc-value { font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 600; color: #0d2137; }

.rc-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
}

.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
}

.status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
}

.status-active {
    background: #e6f9f0;
    color: #1a7a4a;
}
.status-active .status-dot {
    background: #22c55e;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: #ffffff;
    background: #0d2137;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
}

.btn-primary:hover {
    background: #163d5c;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(13, 33, 55, 0.25);
}
</style>

@code {
    
    private decimal _totalDonations;
    private decimal _totalOfferings;
    private decimal _totalTithes;
    private decimal _totalOverallCollections;

    private List<LocalChurchMock> _localChurches = new();

    protected override void OnInitialized()
    {
        // Generate mock data for demonstration
        _localChurches = new List<LocalChurchMock>
        {
            new LocalChurchMock { Id = 1, Name = "Grace Community Church", Location = "Downtown Area", Donations = 15000, Offerings = 25000, Tithes = 45000 },
            new LocalChurchMock { Id = 2, Name = "New Life Fellowship", Location = "North District", Donations = 8000, Offerings = 12000, Tithes = 22000 },
            new LocalChurchMock { Id = 3, Name = "Rivers of Joy", Location = "East Side", Donations = 5000, Offerings = 9500, Tithes = 18000 },
            new LocalChurchMock { Id = 4, Name = "Faith Tabernacle", Location = "West Valley", Donations = 12500, Offerings = 18000, Tithes = 35000 },
            new LocalChurchMock { Id = 5, Name = "Hope Center", Location = "South Ridge", Donations = 20000, Offerings = 30000, Tithes = 55000 },
            new LocalChurchMock { Id = 6, Name = "Victory Chapel", Location = "Central Plaza", Donations = 11000, Offerings = 15500, Tithes = 28000 },
            new LocalChurchMock { Id = 7, Name = "Light of the World", Location = "Hilltop Region", Donations = 6500, Offerings = 8000, Tithes = 14500 }
        };

        _totalDonations = _localChurches.Sum(c => c.Donations);
        _totalOfferings = _localChurches.Sum(c => c.Offerings);
        _totalTithes = _localChurches.Sum(c => c.Tithes);
        _totalOverallCollections = _localChurches.Sum(c => c.OverallTotal);
    }

    private async Task RequestCollection(LocalChurchMock church)
    {
        if (!church.HasRequestedCollection)
        {
            church.HasRequestedCollection = true;
            
            // Deduct 10%
            church.Donations -= church.Donations * 0.10m;
            church.Offerings -= church.Offerings * 0.10m;
            church.Tithes -= church.Tithes * 0.10m;

            // Recalculate totals
            _totalDonations = _localChurches.Sum(c => c.Donations);
            _totalOfferings = _localChurches.Sum(c => c.Offerings);
            _totalTithes = _localChurches.Sum(c => c.Tithes);
            _totalOverallCollections = _localChurches.Sum(c => c.OverallTotal);

            StateHasChanged();
        }
    }

    public class LocalChurchMock
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Location { get; set; } = "";
        public decimal Donations { get; set; }
        public decimal Offerings { get; set; }
        public decimal Tithes { get; set; }
        public decimal OverallTotal => Donations + Offerings + Tithes;
        public bool HasRequestedCollection { get; set; } = false;
    }
}
