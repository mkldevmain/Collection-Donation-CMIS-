@page "/board-of-directors/financial/proposals"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Models
@using CMIS.Services.FinancialApi
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject IFinancialApiClient FinancialApi
@rendermode InteractiveServer

<PageTitle>Budget Proposals — Board of Directors</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Financial Management</h1>
    <p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p>
</div>

<!-- Tab Bar (5 tabs for Board of Directors) -->
<div class="tab-bar">
    <a href="/board-of-directors/financial/proposals" data-enhance-nav="false" class="tab active">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Budget Proposals
    </a>
    <a href="/board-of-directors/financial/transactions" data-enhance-nav="false" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Transactions
    </a>
    <a href="/board-of-directors/financial/allocation" data-enhance-nav="false" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Budget Allocation
    </a>
    <a href="/board-of-directors/financial/monitoring" data-enhance-nav="false" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        Monitoring
    </a>
    <a href="/board-of-directors/financial/reports" data-enhance-nav="false" class="tab">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Reports
    </a>
</div>

<!-- Authority Banner -->
<div style="display:flex;align-items:center;gap:0.6rem;padding:0.75rem 1rem;background:#fffcf5;border:1px solid #f0d9a0;border-radius:8px;margin-bottom:1.5rem;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d35400" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    <span style="font-family:'Inter',sans-serif;font-size:0.85rem;color:#5d4e37;"><strong>Board of Directors</strong> creates the <strong>National Budget</strong> directly via <strong>Budget Allocation</strong> — no proposal submission required.</span>
</div>

<!-- Sub-tabs -->
<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
    <button @onclick='() => { activeSubTab = "all"; ResetPage(); }' style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "all" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "all" ? "#0d2137" : "#fff");color:@(activeSubTab == "all" ? "#fff" : "#6b7c93");transition:all 0.2s;">
        All Proposals
        <span style="background:@(activeSubTab == "all" ? "rgba(255,255,255,0.2)" : "#e8ecf1");padding:0.1rem 0.4rem;border-radius:10px;font-size:0.68rem;">@allProposals.Count</span>
    </button>
</div>

<!-- Toolbar -->
<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.85rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;flex:1;min-width:200px;max-width:400px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search proposals..." @bind="searchQuery" @bind:event="oninput" @bind:after="ResetPage" style="border:none;outline:none;background:none;font-family:'Inter',sans-serif;font-size:0.84rem;color:#1a1a2e;width:100%;" />
    </div>
    <select @bind="statusFilter" @bind:after="ResetPage" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:120px;">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Disapproved">Disapproved</option>
    </select>
    <select @bind="levelFilter" @bind:after="ResetPage" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:130px;">
        <option value="">All Levels</option>
        <option value="Local Church">Local Church</option>
        <option value="District">District</option>
    </select>
    @if (!string.IsNullOrEmpty(levelFilter))
    {
        <select @bind="fromFilter" @bind:after="ResetPage" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:150px;">
            @if (levelFilter == "Local Church")
            {
                <option value="0">All Churches</option>
                @foreach (var c in churches)
                {
                    <option value="@c.ChurchId">@c.ChurchName</option>
                }
            }
            else
            {
                <option value="0">All Districts</option>
                @foreach (var d in districts)
                {
                    <option value="@d.DistrictId">@d.DistrictName</option>
                }
            }
        </select>
    }
</div>

<!-- Data Table -->
<div style="background:#fff;border-radius:12px;border:1px solid #e8ecf1;overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:0.84rem;table-layout:fixed;">
        <colgroup><col style="width:10%"/><col style="width:22%"/><col style="width:9%"/><col style="width:15%"/><col style="width:10%"/><col style="width:14%"/><col style="width:12%"/><col style="width:8%"/></colgroup>
        <thead style="background:#f8fafc;">
            <tr>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;letter-spacing:0.04em;border-bottom:1px solid #e8ecf1;">ID</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Purpose</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Level</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">From</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Amount</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Submission</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Status</th>
                <th style="padding:0.75rem 1rem;text-align:center;font-weight:600;font-size:0.75rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (displayedProposals.Any())
            {
                foreach (var p in pagedProposals)
                {
                    var statusColor = p.Status == "Approved" ? "#27ae60" : p.Status == "Disapproved" ? "#c0392b" : "#e67e22";
                    var statusBg = p.Status == "Approved" ? "#eafaf1" : p.Status == "Disapproved" ? "#fdedec" : "#fef9e7";
                    var levelBg = p.Level == "Local Church" ? "#e8f4f8" : "#f4f6f7";
                    var levelColor = p.Level == "Local Church" ? "#1a5276" : "#5d6d7e";
                    <tr style="border-bottom:1px solid #f0f3f6;">
                        <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">@p.ProposalCode</td>
                        <td style="padding:0.85rem 1rem;">
                            <span style="font-weight:600;color:#0d2137;display:block;">@p.Purpose</span>
                            <span style="font-size:0.72rem;color:#8e99a4;display:block;">@p.MinistryName</span>
                        </td>
                        <td style="padding:0.85rem 1rem;">
                            <span style="padding:0.2rem 0.5rem;border-radius:4px;font-size:0.7rem;font-weight:700;background:@levelBg;color:@levelColor;">@p.Level</span>
                        </td>
                        <td style="padding:0.85rem 1rem;">
                            <span style="font-weight:600;color:#0d2137;display:block;font-size:0.82rem;">
                                @(p.Level == "District" ? p.DistrictName : p.Level == "Local Church" ? p.ChurchName : p.MinistryName ?? "—")
                            </span>
                            <span style="font-size:0.68rem;color:#8e99a4;">@p.Level</span>
                        </td>
                        <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">$@p.Amount.ToString("N0")</td>
                        <td style="padding:0.85rem 1rem;font-size:0.78rem;color:#2c3e50;">@(p.SubmittedByFirstName + " " + p.SubmittedByLastName)</td>
                        <td style="padding:0.85rem 1rem;">
                            <span style="display:inline-flex;align-items:center;gap:0.3rem;padding:0.2rem 0.6rem;border-radius:12px;font-size:0.72rem;font-weight:600;background:@statusBg;color:@statusColor;">
                                <span style="width:6px;height:6px;border-radius:50%;background:@statusColor;display:inline-block;"></span>
                                @p.Status
                            </span>
                        </td>
                        <td style="padding:0.85rem 1rem;text-align:center;">
                            <svg @onclick="() => OpenViewModal(p)" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2" style="cursor:pointer;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" style="padding:3rem;text-align:center;color:#6b7c93;font-size:0.85rem;">
                        No proposals found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (propTotalPages > 1)
{
    <div style="display:flex;justify-content:center;padding:0.75rem 0 0.25rem;">
        <MudPagination Count="@propTotalPages" @bind-Selected="propPage" Color="Color.Primary" Size="Size.Small" />
    </div>
}

@if (showViewModal && viewProposal != null)
{
    var sBg = viewProposal.Status == "Approved" ? "#eafaf1" : viewProposal.Status == "Disapproved" ? "#fdedec" : "#fef9e7";
    var sColor = viewProposal.Status == "Approved" ? "#1e8449" : viewProposal.Status == "Disapproved" ? "#c0392b" : "#b7950b";
    var sDot = viewProposal.Status == "Approved" ? "#27ae60" : viewProposal.Status == "Disapproved" ? "#e74c3c" : "#d4ac0d";
    <div style="position:fixed;inset:0;z-index:1000;background:rgba(13,33,55,0.45);display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseViewModal">
        <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:520px;box-shadow:0 20px 60px rgba(13,33,55,0.25);display:flex;flex-direction:column;gap:1.1rem;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;margin:0;">Proposal Details</h2>
                <span style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.3rem 0.7rem;border-radius:20px;font-size:0.75rem;font-weight:600;background:@sBg;color:@sColor;">
                    <span style="width:7px;height:7px;border-radius:50%;background:@sDot;display:inline-block;"></span>
                    @viewProposal.Status
                </span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Proposal ID</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#0d2137;font-weight:600;">@viewProposal.ProposalCode</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Level</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@viewProposal.Level</div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.3rem;">
                <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Purpose</span>
                <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@viewProposal.Purpose</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(viewProposal.Description))
            {
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Description</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;white-space:pre-wrap;">@viewProposal.Description</div>
                </div>
            }
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">From</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@GetFromLabel(viewProposal)</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Amount</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#0d2137;font-weight:600;">$@viewProposal.Amount.ToString("N2")</div>
                </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Submitted By</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@(viewProposal.SubmittedByFirstName + " " + viewProposal.SubmittedByLastName)</div>
                </div>
                <div style="display:flex;flex-direction:column;gap:0.3rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">Date Submitted</span>
                    <div style="padding:0.55rem 0.8rem;background:#f8fafc;border:1.5px solid #e8ecf1;border-radius:8px;font-family:'Inter',sans-serif;font-size:0.88rem;color:#1a1a2e;">@viewProposal.CreatedAt.ToString("MMM d, yyyy")</div>
                </div>
            </div>
            <div style="display:flex;justify-content:flex-end;margin-top:0.25rem;">
                <button @onclick="CloseViewModal" style="padding:0.65rem 1.4rem;font-family:'Inter',sans-serif;font-size:0.88rem;font-weight:600;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private List<BudgetProposalReadDto> allProposals = new();
    private List<Church> churches = new();
    private List<District> districts = new();
    private string activeSubTab = "all";
    private string searchQuery = "";
    private string statusFilter = "";
    private string levelFilter = "";
    private int fromFilter = 0;

    private bool showViewModal = false;
    private BudgetProposalReadDto? viewProposal = null;

    private void OpenViewModal(BudgetProposalReadDto p) { viewProposal = p; showViewModal = true; }
    private void CloseViewModal() { showViewModal = false; viewProposal = null; }
    private string GetFromLabel(BudgetProposalReadDto p) =>
        p.Level == "District" ? p.DistrictName ?? "—" :
        p.Level == "Local Church" ? p.ChurchName ?? "—" :
        p.MinistryName ?? "—";

    protected override async Task OnInitializedAsync()
    {
        var allFromApi = await FinancialApi.GetProposalsAsync();
        allProposals = allFromApi
            .Where(p => p.Level != "Ministry")
            .OrderByDescending(p => p.CreatedAt)
            .ToList();

        churches = await Db.Set<Church>()
            .OrderBy(c => c.ChurchName)
            .ToListAsync();

        districts = await Db.Set<District>()
            .OrderBy(d => d.DistrictName)
            .ToListAsync();
    }

    private List<BudgetProposalReadDto> displayedProposals
    {
        get
        {
            var source = allProposals;

            var q = source.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var s = searchQuery.Trim().ToLower();
                q = q.Where(p => p.Purpose.ToLower().Contains(s) || p.ProposalCode.ToLower().Contains(s));
            }
            if (!string.IsNullOrEmpty(statusFilter))
                q = q.Where(p => p.Status == statusFilter);
            if (!string.IsNullOrEmpty(levelFilter))
                q = q.Where(p => p.Level == levelFilter);
            if (fromFilter > 0)
            {
                if (levelFilter == "Local Church")
                    q = q.Where(p => p.ChurchId == fromFilter);
                else if (levelFilter == "District")
                    q = q.Where(p => p.DistrictId == fromFilter);
            }

            return q.ToList();
        }
    }

    private int propPage = 1;
    private const int PropPageSize = 10;
    private void ResetPage() => propPage = 1;
    private List<BudgetProposalReadDto> pagedProposals => displayedProposals.Skip((propPage - 1) * PropPageSize).Take(PropPageSize).ToList();
    private int propTotalPages => Math.Max(1, (int)Math.Ceiling((double)displayedProposals.Count / PropPageSize));
}
