@using CMIS.Store.Audit

<MudCard Elevation="2" Class="rounded-xl mt-6">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Immutable Audit Log</MudText>
        </CardHeaderContent>
        <CardHeaderActions>
            <MudIconButton Icon="@Icons.Material.Filled.FilterList" Color="Color.Default" />
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Class="pa-0">
        <MudTable Items="@AuditLogs" Hover="true" Elevation="0" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Timestamp</MudTh>
                <MudTh>Action</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Modified By</MudTh>
                <MudTh>Details</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2" Class="fw-semibold">@context.Timestamp.ToString("MMM dd, yyyy HH:mm")</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@GetActionColor(context.ActionType)" Variant="Variant.Text" Class="fw-bold">@context.ActionType</MudChip>
                </MudTd>
                <MudTd>@context.ReferenceTable</MudTd>
                <MudTd>@context.ModifiedBy</MudTd>
                <MudTd>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.caption" Class="text-red-400">Prev: @context.PreviousValue</MudText>
                        <MudText Typo="Typo.caption" Class="text-green-400">New: @context.UpdatedValue</MudText>
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public IEnumerable<AuditLogEntry> AuditLogs { get; set; } = new List<AuditLogEntry>();

    private Color GetActionColor(string action) => action?.ToUpper() switch
    {
        "INSERT" => Color.Success,
        "UPDATE" => Color.Warning,
        "ARCHIVE" => Color.Error,
        _ => Color.Default
    };
}
