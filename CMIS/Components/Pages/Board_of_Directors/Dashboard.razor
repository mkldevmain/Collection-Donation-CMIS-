@page "/board-of-directors"
@layout CMIS.Components.Layout.DashboardLayout
@rendermode InteractiveServer

<PageTitle>Dashboard — CMIS Portal</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Welcome back. Here's an overview of the board's financial activities.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:#e8f4f8;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a5276" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Financial Management</span>
            <a href="/board-of-directors/financial/proposals" class="stat-value" style="font-size:0.85rem;color:#1a5276;text-decoration:none;">Open &rarr;</a>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fef9e7;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d4ac0d" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Audit</span>
            <a href="/board-of-directors/audit" class="stat-value" style="font-size:0.85rem;color:#d4ac0d;text-decoration:none;">Open &rarr;</a>
        </div>
    </div>
</div>
