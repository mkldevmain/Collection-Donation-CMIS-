@using CMIS.Components.Pages.Ministry_Head.Collection_Donation

<!-- Entry Form -->
<div class="form-card">
    <h2 class="form-title">Record New Donation</h2>
    <div class="form-grid">
        <div class="form-group" style="position: relative;">
            <label class="form-label">Donor Name</label>
            <input type="text" class="form-input" placeholder="Search or type donor name..."
                   value="@NewDonor" @oninput="@(e => NewDonorChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                   @onfocus="() => ShowDonorDropdown = true"
                   @onblur="OnBlur"
                   id="input-donor" autocomplete="off" />
            @if (ShowDonorDropdown && FilteredMembers.Any())
            {
                <div class="autocomplete-dropdown">
                    @foreach (var m in FilteredMembers.Take(8))
                    {
                        <div class="autocomplete-item" @onmousedown="() => OnSelectDonor.InvokeAsync(m)">
                            <span class="autocomplete-name">@m.FirstName @m.LastName</span>
                            <span class="autocomplete-meta">Member</span>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="form-group">
            <label class="form-label">Donation Type</label>
            <select class="form-input" value="@NewType" @onchange="@(e => NewTypeChanged.InvokeAsync(e.Value?.ToString() ?? ""))" id="select-type">
                <option value="Tithe">Tithe</option>
                <option value="Offering">Offering</option>
                <option value="Donation">Donation</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Amount (₱)</label>
            <input type="number" class="form-input" placeholder="0.00" value="@NewAmount" @oninput="@(e => { if (decimal.TryParse(e.Value?.ToString(), out var v)) NewAmountChanged.InvokeAsync(v); })" id="input-amount" />
        </div>
        <div class="form-group">
            <label class="form-label">Date</label>
            <input type="date" class="form-input" value="@(NewDate.ToString("yyyy-MM-dd"))" @onchange="@(e => { if (DateTime.TryParse(e.Value?.ToString(), out var d)) NewDateChanged.InvokeAsync(d); })" id="input-date" />
        </div>
        <div class="form-group">
            <label class="form-label">Notes</label>
            <input type="text" class="form-input" placeholder="Optional notes" value="@NewNotes" @oninput="@(e => NewNotesChanged.InvokeAsync(e.Value?.ToString() ?? ""))" id="input-notes" />
        </div>
    </div>
    <div class="form-actions">

        <button class="btn-primary" @onclick="OnAddDonation" id="btn-add-entry">+ Add Entry</button>
        <button class="btn-secondary" @onclick="OnClearForm" id="btn-clear">Clear Form</button>
    </div>
</div>

<!-- Segmented Control -->
<div class="segmented-control">
    <button class="segment-btn @(titheSubTab == "tithes" ? "active" : "")" @onclick='() => titheSubTab = "tithes"'>Tithes</button>
    <button class="segment-btn @(titheSubTab == "offerings" ? "active" : "")" @onclick='() => titheSubTab = "offerings"'>Offerings</button>
    <button class="segment-btn @(titheSubTab == "donations" ? "active" : "")" @onclick='() => titheSubTab = "donations"'>Donations</button>
</div>

@{
    var currentList = titheSubTab == "tithes" ? FilteredTithes
                    : titheSubTab == "offerings" ? FilteredOfferings
                    : FilteredDonations;
    var searchLabel = titheSubTab == "tithes" ? "tithes" : titheSubTab == "offerings" ? "offerings" : "donations";
}

<div class="toolbar">
    <div class="search-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="search-input" placeholder="Search @searchLabel..." @bind="searchQuery" @bind:event="oninput" />
    </div>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>ENTRY ID</th>
                <th>DONOR NAME</th>
                <th>AMOUNT</th>
                <th>DATE</th>
                <th>STATUS</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            @if (currentList.Any())
            {
                @foreach (var d in currentList)
                {
                    <tr>
                        <td class="col-id">@d.Id</td>
                        <td>
                            <div class="col-donor">
                                <span class="donor-name">@d.DonorName</span>
                                <span class="donor-sub">@d.Type · @d.Date.ToString("MMM dd, yyyy")</span>
                            </div>
                        </td>
                        <td class="col-amount">₱@d.Amount.ToString("N0")</td>
                        <td>@d.Date.ToString("MMM dd, yyyy")</td>
                        <td><span class="status-badge status-finalized"><span class="status-dot"></span>Finalized</span></td>
                        <td class="col-actions">
                            <button class="action-btn" title="View" @onclick="() => OnViewRecord.InvokeAsync(d)">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="empty-state">No @searchLabel records found.</td></tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public List<DonationEntry> FilteredTithes { get; set; } = new();
    [Parameter] public List<DonationEntry> FilteredOfferings { get; set; } = new();
    [Parameter] public List<DonationEntry> FilteredDonations { get; set; } = new();
    [Parameter] public List<CMIS.Models.Profile> FilteredMembers { get; set; } = new();
    [Parameter] public bool ShowDonorDropdown { get; set; }
    [Parameter] public string NewDonor { get; set; } = "";
    [Parameter] public string NewType { get; set; } = "Tithe";
    [Parameter] public string NewNotes { get; set; } = "";
    [Parameter] public decimal NewAmount { get; set; }
    [Parameter] public DateTime NewDate { get; set; } = DateTime.Today;
    [Parameter] public EventCallback<CMIS.Models.Profile> OnSelectDonor { get; set; }
    [Parameter] public EventCallback OnAddDonation { get; set; }
    [Parameter] public EventCallback OnClearForm { get; set; }
    [Parameter] public EventCallback OnBlur { get; set; }
    [Parameter] public EventCallback<DonationEntry> OnViewRecord { get; set; }

    [Parameter] public EventCallback<string> NewDonorChanged { get; set; }
    [Parameter] public EventCallback<string> NewTypeChanged { get; set; }
    [Parameter] public EventCallback<string> NewNotesChanged { get; set; }
    [Parameter] public EventCallback<decimal> NewAmountChanged { get; set; }
    [Parameter] public EventCallback<DateTime> NewDateChanged { get; set; }

    private string titheSubTab = "tithes";
    private string searchQuery = "";
}
