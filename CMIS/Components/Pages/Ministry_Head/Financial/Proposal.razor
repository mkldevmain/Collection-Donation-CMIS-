@page "/ministry-head/financial/proposals"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Services.FinancialApi
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject IFinancialApiClient FinancialApi
@inject NavigationManager Navigation
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Financial Management &mdash; CMIS Portal</PageTitle>

<div class="page-heading"><h1 class="page-title">Financial Management</h1><p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p></div>

<div class="tab-bar">
    <a href="/ministry-head/financial/proposals" data-enhance-nav="false" class="tab active">Budget Proposals</a>
    <a href="/ministry-head/financial/transactions" data-enhance-nav="false" class="tab">Transactions</a>
    <a href="/ministry-head/financial/monitoring" data-enhance-nav="false" class="tab">Monitoring</a>
    <a href="/ministry-head/financial/reports" data-enhance-nav="false" class="tab">Reports</a>
</div>

<div class="authority-banner">Your authority: Create <strong>Ministry</strong> budget proposals and submit them to <strong>Head Pastor</strong> for approval.</div>

<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
    <button @onclick="ShowMine" style="padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "mine" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "mine" ? "#0d2137" : "#fff");color:@(activeSubTab == "mine" ? "#fff" : "#6b7c93");">My Proposals (@myProposals.Count)</button>
    <button @onclick="ShowAll"  style="padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "all"  ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "all"  ? "#0d2137" : "#fff");color:@(activeSubTab == "all"  ? "#fff" : "#6b7c93");">All Proposals (@allProposals.Count)</button>
</div>

<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.85rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;flex:1;min-width:200px;max-width:400px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search proposals..." @bind="searchQuery" @bind:event="oninput" style="border:none;outline:none;background:none;font-family:'Inter',sans-serif;font-size:0.84rem;color:#1a1a2e;width:100%;" />
    </div>
    <select @bind="statusFilter" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:120px;">
        <option value="">All Statuses</option>
        <option value="Pending">Pending</option>
        <option value="Approved">Approved</option>
        <option value="Disapproved">Disapproved</option>
        <option value="For Revision">For Revision</option>
    </select>
    @if (activeSubTab == "all")
    {
        <select @bind="ministryFilter" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:140px;">
            <option value="0">All Ministries</option>
            @foreach (var m in ministries) { <option value="@m.MinistryId">@m.MinistryName</option> }
        </select>
    }
    <button @onclick="OpenModal" style="margin-left:auto;padding:0.6rem 1.2rem;font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;white-space:nowrap;">+ New Ministry Proposal</button>
</div>

<div class="table-container">
    <table class="proposals-table">
        <thead>
            <tr>
                <th>ID</th><th>Purpose</th><th>Ministry</th><th>Amount</th><th>Submission</th><th>Status</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @{var rows = pagedProposals;}
            @if (rows.Any())
            {
                @foreach (var p in rows)
                {
                    <tr>
                        <td class="col-id">@p.ProposalCode</td>
                        <td class="col-purpose"><span class="purpose-title">@p.Purpose</span><span class="purpose-ministry">@p.MinistryName</span></td>
                        <td><span class="level-badge">@p.MinistryName</span></td>
                        <td class="col-amount">$@p.Amount.ToString("N0")</td>
                        <td class="col-submission"><span class="submission-from">Ministry Head</span><span class="submission-arrow">&rarr; Head Pastor</span></td>
                        <td><span class="status-badge status-@p.Status.ToLower().Replace(" ", "-")"><span class="status-dot"></span>@p.Status</span></td>
                        <td class="col-actions"><button class="action-btn" @onclick="() => OpenViewModal(p)">View</button></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="empty-state">No proposals found.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (propTotalPages > 1)
{
    <div style="display:flex;justify-content:center;padding:0.75rem 0;">
        <MudPagination Count="@propTotalPages" @bind-Selected="propPage" Color="Color.Primary" Size="Size.Small" />
    </div>
}

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h2 class="modal-title">New Ministry Proposal</h2>
            <div class="modal-field"><label class="modal-label">Purpose</label><input type="text" class="modal-input" @bind="newPurpose" /></div>
            <div class="modal-field"><label class="modal-label">Description (Optional)</label><textarea class="modal-input modal-textarea" @bind="newDescription" rows="3"></textarea></div>
            <div class="modal-row">
                <div class="modal-field">
                    <label class="modal-label">Ministry</label>
                    <select class="modal-select" @bind="newMinistryId">
                        <option value="0">-- Select Ministry --</option>
                        @foreach (var m in ministries) { <option value="@m.MinistryId">@m.MinistryName</option> }
                    </select>
                </div>
                <div class="modal-field"><label class="modal-label">Level</label><div class="modal-level-fixed">Ministry</div></div>
            </div>
            <div class="modal-field"><label class="modal-label">Amount ($)</label><input type="number" class="modal-input" step="0.01" min="0" @bind="newAmount" /></div>
            @if (!string.IsNullOrEmpty(modalError)) { <p class="modal-error">@modalError</p> }
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="CloseModal">Cancel</button>
                <button class="modal-btn-save" @onclick="SaveProposal" disabled="@isSaving">@(isSaving ? "Submitting..." : "Submit")</button>
            </div>
        </div>
    </div>
}

@if (showViewModal && viewProposal != null)
{
    <div class="modal-overlay" @onclick="CloseViewModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <h2 class="modal-title">Proposal Details</h2>
                <span class="status-badge status-@viewProposal.Status.ToLower().Replace(" ", "-")"><span class="status-dot"></span>@viewProposal.Status</span>
            </div>
            <div class="modal-field"><label class="modal-label">ID</label><div class="modal-view-value">@viewProposal.ProposalCode</div></div>
            <div class="modal-field"><label class="modal-label">Purpose</label><div class="modal-view-value">@viewProposal.Purpose</div></div>
            @if (!string.IsNullOrWhiteSpace(viewProposal.Description))
            {
                <div class="modal-field"><label class="modal-label">Description</label><div class="modal-view-value" style="white-space:pre-wrap;">@viewProposal.Description</div></div>
            }
            <div class="modal-row">
                <div class="modal-field"><label class="modal-label">Ministry</label><div class="modal-view-value">@viewProposal.MinistryName</div></div>
                <div class="modal-field"><label class="modal-label">Level</label><div class="modal-view-value">@viewProposal.Level</div></div>
            </div>
            <div class="modal-row">
                <div class="modal-field"><label class="modal-label">Amount</label><div class="modal-view-value">$@viewProposal.Amount.ToString("N2")</div></div>
                <div class="modal-field"><label class="modal-label">Submitted</label><div class="modal-view-value">@viewProposal.CreatedAt.ToString("MMM d, yyyy")</div></div>
            </div>
            @if (viewProposal.Status == "Disapproved" || viewProposal.Status == "For Revision")
            {
                <div class="modal-field">
                    <label class="modal-label">@(viewProposal.Status == "Disapproved" ? "Rejection Reason" : "Revision Notes")</label>
                    <div class="modal-view-value">@viewProposal.RejectionReason</div>
                </div>
            }
            <div class="modal-actions"><button class="modal-btn-cancel" @onclick="CloseViewModal">Close</button></div>
        </div>
    </div>
}

@code {
    private List<BudgetProposalReadDto> allProposals = new();
    private List<Ministry> ministries = new();
    private string activeSubTab = "mine";

    private string _searchQuery = "";
    private string searchQuery { get => _searchQuery; set { _searchQuery = value; propPage = 1; } }

    private string _statusFilter = "";
    private string statusFilter { get => _statusFilter; set { _statusFilter = value; propPage = 1; } }

    private int _ministryFilter = 0;
    private int ministryFilter { get => _ministryFilter; set { _ministryFilter = value; propPage = 1; } }
    private int currentProfileId = 0;
    private int currentChurchId = 0;
    private int? currentDistrictId = null;

    private List<BudgetProposalReadDto> myProposals =>
        allProposals.Where(p => p.SubmittedById == currentProfileId).ToList();

    private List<BudgetProposalReadDto> displayedProposals
    {
        get
        {
            var source = activeSubTab switch
            {
                "mine" => myProposals,
                _      => allProposals
            };
            var q = source.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var s = searchQuery.Trim().ToLower();
                q = q.Where(p => p.ProposalCode.ToLower().Contains(s)
                               || p.Purpose.ToLower().Contains(s)
                               || (p.MinistryName ?? "").ToLower().Contains(s));
            }
            if (!string.IsNullOrEmpty(statusFilter)) q = q.Where(p => p.Status == statusFilter);
            if (ministryFilter > 0 && activeSubTab == "all") q = q.Where(p => p.MinistryId == ministryFilter);
            return q.ToList();
        }
    }

    private void ShowMine() { activeSubTab = "mine"; propPage = 1; }
    private void ShowAll()  { activeSubTab = "all";  propPage = 1; }

    private int propPage = 1;
    private const int PropPageSize = 10;
    private void ResetPage() => propPage = 1;
    private List<BudgetProposalReadDto> pagedProposals =>
        displayedProposals.Skip((propPage - 1) * PropPageSize).Take(PropPageSize).ToList();
    private int propTotalPages =>
        Math.Max(1, (int)Math.Ceiling((double)displayedProposals.Count / PropPageSize));

    private bool showViewModal = false;
    private BudgetProposalReadDto? viewProposal = null;
    private void OpenViewModal(BudgetProposalReadDto p) { viewProposal = p; showViewModal = true; }
    private void CloseViewModal() { showViewModal = false; viewProposal = null; }

    private bool showModal = false;
    private bool isSaving = false;
    private string newPurpose = "";
    private string newDescription = "";
    private int newMinistryId = 0;
    private decimal newAmount = 0;
    private string modalError = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (claim != null && int.TryParse(claim.Value, out int accountId))
        {
            var account = await Db.Accounts
                .Include(a => a.Church)
                .Include(a => a.Profile).ThenInclude(p => p!.Church)
                .FirstOrDefaultAsync(a => a.AccountId == accountId);
            currentProfileId = account?.ProfileId ?? 0;
            currentChurchId = account?.ChurchId ?? account?.Profile?.ChurchId ?? 0;
            currentDistrictId = account?.Church?.DistrictId ?? account?.Profile?.Church?.DistrictId;
        }

        await LoadProposals();

        ministries = await Db.Set<Ministry>()
            .Where(m => m.Status == "Active")
            .OrderBy(m => m.MinistryName)
            .ToListAsync();
    }

    private async Task LoadProposals()
    {
        var raw = await FinancialApi.GetProposalsAsync(churchId: currentChurchId > 0 ? currentChurchId : null);
        allProposals = raw.OrderByDescending(p => p.CreatedAt).ToList();
    }

    private void OpenModal()
    {
        newPurpose = ""; newDescription = "";
        newMinistryId = ministries.FirstOrDefault()?.MinistryId ?? 0;
        newAmount = 0; modalError = "";
        showModal = true;
    }

    private void CloseModal() { showModal = false; modalError = ""; }

    private async Task SaveProposal()
    {
        modalError = "";
        if (string.IsNullOrWhiteSpace(newPurpose)) { modalError = "Purpose required."; return; }
        if (newMinistryId == 0) { modalError = "Select a ministry."; return; }
        if (newAmount <= 0) { modalError = "Amount must be greater than 0."; return; }
        if (currentProfileId == 0) { modalError = "Cannot identify user."; return; }

        isSaving = true;
        try
        {
            int nextNum = (allProposals
                .Select(p => p.ProposalCode)
                .Where(c => c.StartsWith("BP-"))
                .Select(c => int.TryParse(c[3..], out var n) ? n : 0)
                .DefaultIfEmpty(1000)
                .Max()) + 1;

            await FinancialApi.CreateProposalAsync(new BudgetProposalCreateDto
            {
                ProposalCode  = $"BP-{nextNum}",
                Purpose       = newPurpose.Trim(),
                Description   = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim(),
                MinistryId    = newMinistryId,
                ChurchId      = currentChurchId > 0 ? currentChurchId : null,
                DistrictId    = currentDistrictId,
                Level         = "Ministry",
                Amount        = newAmount,
                SubmittedById = currentProfileId
            });
            await LoadProposals();
            showModal = false;
        }
        catch (Exception ex) { modalError = $"Save failed: {ex.Message}"; }
        isSaving = false;
    }
}
