@using CMIS.Models
@inject NavigationManager NavManager

<style>
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
    }
    .day-header {
        padding: 12px 16px;
        font-weight: 700;
        color: #062b63;
        font-size: 14px;
        border-right: 1px solid #e2e8f0;
        border-bottom: 2px solid #e2e8f0;
        text-align: left;
    }
    .day-header:last-child { border-right: none; }
    
    .day-cell {
        min-height: 140px;
        padding: 12px;
        border-right: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
        background: #fff;
        position: relative;
    }
    .day-cell:nth-child(7n) { border-right: none; }
    .day-cell.other-month { background: #f1f5f9; color: #94a3b8; }
    
    .day-num {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
        display: block;
    }
    
    .event-bubble {
        background: #dbeafe;
        color: #1e40af;
        padding: 8px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        text-align: center;
        line-height: 1.3;
        cursor: pointer;
        transition: transform 0.1s;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .event-bubble:hover { transform: scale(1.02); }
    .event-title-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        width: 100%;
    }
    .event-venue-text {
        font-size: 9px;
        opacity: 0.8;
    }
    .circle-btn:hover {
        border-color: #062b63 !important;
        color: #062b63 !important;
        background: #f8fafc !important;
    }
</style>



<div class="calendar-grid">
    @foreach (var day in daysOfWeek)
    {
        <div class="day-header">@day</div>
    }

    @foreach (var cell in calendarCells)
    {
        <div class="day-cell @(cell.IsOtherMonth ? "other-month" : "")">
            <span class="day-num">@cell.Date.Day</span>
            <div style="display:flex; flex-direction:column; gap:6px;">
                @foreach (var ev in Events.Where(e => e.Date.Date == cell.Date.Date).Take(2))
                {
                    var statusColor = GetStatusColor(ev.Status);
                    <div class="event-bubble" style="background:@statusColor.bg; color:@statusColor.text; border:1px solid @statusColor.border;" @onclick="() => NavigateToEvent(ev.Id)">
                        <div class="event-title-text">@ev.Title</div>
                        <div class="event-venue-text">@ev.Venue</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public List<EventModel> Events { get; set; } = new();

    [Parameter]
    public DateTime ViewDate { get; set; } = DateTime.Today;

    private string[] daysOfWeek = { "MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN" };
    private List<CalendarCell> calendarCells = new();

    protected override void OnParametersSet()
    {
        GenerateCalendar();
    }

    private void GenerateCalendar()
    {
        calendarCells.Clear();
        var firstDayOfMonth = new DateTime(ViewDate.Year, ViewDate.Month, 1);
        
        int diff = (7 + (int)firstDayOfMonth.DayOfWeek - (int)DayOfWeek.Monday) % 7;
        var startOfGrid = firstDayOfMonth.AddDays(-diff);
        
        for (int i = 0; i < 42; i++)
        {
            var date = startOfGrid.AddDays(i);
            calendarCells.Add(new CalendarCell
            {
                Date = date,
                IsOtherMonth = date.Month != ViewDate.Month
            });
        }
    }

    private void NavigateToEvent(int id) => NavManager.NavigateTo($"/event-details/{id}");

    private (string bg, string text, string border) GetStatusColor(string status) => status switch
    {
        "Planned Event" => ("#eef2ff", "#6366f1", "#c7d2fe"),
        "Under Review" => ("#fffbeb", "#d97706", "#fef3c7"),
        "Approved" => ("#ecfdf5", "#10b981", "#a7f3d0"),
        "Published" => ("#eff6ff", "#3b82f6", "#bfdbfe"),
        "Ended" => ("#f8fafc", "#475569", "#cbd5e1"),
        "Rejected" => ("#fef2f2", "#ef4444", "#fecaca"),
        "Rescheduled" => ("#f5f3ff", "#8b5cf6", "#ddd6fe"),
        _ => ("#f8fafc", "#64748b", "#e2e8f0")
    };

    public class CalendarCell
    {
        public DateTime Date { get; set; }
        public bool IsOtherMonth { get; set; }
    }
}
