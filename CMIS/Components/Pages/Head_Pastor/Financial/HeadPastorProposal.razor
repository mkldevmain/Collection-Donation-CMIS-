@page "/head-pastor/financial/proposals"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Models
@using CMIS.Services
@using CMIS.Services.FinancialApi
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject IFinancialApiClient FinancialApi
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Budget Proposals — Head Pastor</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Financial Management</h1>
    <p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p>
</div>

<div class="tab-bar">
    <a href="/head-pastor/financial/proposals" data-enhance-nav="false" class="tab active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Budget Proposals</a>
    <a href="/head-pastor/financial/transactions" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Transactions</a>
    <a href="/head-pastor/financial/allocation" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Budget Allocation</a>
    <a href="/head-pastor/financial/monitoring" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> Monitoring</a>
    <a href="/head-pastor/financial/reports" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Reports</a>
</div>

<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
    <button @onclick="ShowMy"    style="padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "my"    ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "my"    ? "#0d2137" : "#fff");color:@(activeSubTab == "my"    ? "#fff" : "#6b7c93");">My Proposals (@myProposals.Count)</button>
    <button @onclick="ShowInbox" style="padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "inbox" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "inbox" ? "#0d2137" : "#fff");color:@(activeSubTab == "inbox" ? "#fff" : "#6b7c93");">Approval Inbox (@inboxProposals.Count)</button>
    <button @onclick="ShowAll"   style="padding:0.45rem 0.85rem;border-radius:20px;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid @(activeSubTab == "all"   ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "all"   ? "#0d2137" : "#fff");color:@(activeSubTab == "all"   ? "#fff" : "#6b7c93");">All Proposals (@allProposals.Count)</button>
</div>

<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.85rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;flex:1;min-width:200px;max-width:400px;">
        <input type="text" placeholder="Search proposals..." @bind="searchQuery" @bind:event="oninput" style="border:none;outline:none;background:none;font-family:'Inter',sans-serif;font-size:0.84rem;color:#1a1a2e;width:100%;" />
    </div>
    <select @bind="statusFilter" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:120px;">
        <option value="">All Statuses</option><option value="Pending">Pending</option><option value="Approved">Approved</option><option value="Disapproved">Disapproved</option>
    </select>
    @if (activeSubTab == "inbox" || activeSubTab == "all")
    {
        <select @bind="ministryFilter" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:140px;">
            <option value="0">All Ministries</option>
            @foreach (var m in ministries) { <option value="@m.MinistryId">@m.MinistryName</option> }
        </select>
    }
    <button @onclick="OpenModal" style="margin-left:auto;padding:0.6rem 1.2rem;font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;white-space:nowrap;">+ New Local Church Proposal</button>
</div>

<div style="background:#fff;border-radius:12px;border:1px solid #e8ecf1;overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:0.84rem;">
        <thead style="background:#f8fafc;">
            <tr>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">ID</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Purpose</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">From</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Amount</th>
                <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Status</th>
                <th style="padding:0.75rem 1rem;text-align:center;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in pagedProposals)
            {
                var statusColor = p.Status == "Approved" ? "#27ae60" : p.Status == "Disapproved" ? "#c0392b" : "#e67e22";
                var statusBg = p.Status == "Approved" ? "#eafaf1" : p.Status == "Disapproved" ? "#fdedec" : "#fef9e7";
                <tr style="border-bottom:1px solid #f0f3f6;">
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">@p.ProposalCode</td>
                    <td style="padding:0.85rem 1rem;"><span style="font-weight:600;color:#0d2137;display:block;">@p.Purpose</span><span style="font-size:0.72rem;color:#8e99a4;">@p.MinistryName</span></td>
                    <td style="padding:0.85rem 1rem;">@(p.Level == "Ministry" ? p.MinistryName : p.ChurchName ?? "—")</td>
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">$@p.Amount.ToString("N0")</td>
                    <td style="padding:0.85rem 1rem;"><span style="padding:0.2rem 0.6rem;border-radius:12px;font-size:0.72rem;font-weight:600;background:@statusBg;color:@statusColor;">@p.Status</span></td>
                    <td style="padding:0.85rem 1rem;text-align:center;"><svg @onclick="() => OpenViewModal(p)" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2" style="cursor:pointer;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (propTotalPages > 1)
{
    <div style="display:flex;justify-content:center;padding:0.75rem 0 0.25rem;">
        <MudPagination Count="@propTotalPages" @bind-Selected="propPage" Color="Color.Primary" Size="Size.Small" />
    </div>
}

@if (showModal)
{
    <div style="position:fixed;inset:0;z-index:1000;background:rgba(13,33,55,0.45);display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseModal">
        <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:520px;box-shadow:0 20px 60px rgba(13,33,55,0.25);display:flex;flex-direction:column;gap:1.1rem;" @onclick:stopPropagation="true">
            <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;margin:0;">New Local Church Proposal</h2>
            <div><label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Purpose</label><input type="text" @bind="newPurpose" placeholder="Brief purpose" style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;width:100%;box-sizing:border-box;" /></div>
            <div><label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Description</label><textarea @bind="newDescription" rows="3" style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;width:100%;box-sizing:border-box;"></textarea></div>
            <div><label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Church</label><div style="padding:0.65rem 0.85rem;font-weight:600;color:#1a5276;background:#f0f4f8;border:1.5px solid #d1d9e6;border-radius:8px;">@currentChurchName</div></div>
            <div><label style="font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:600;color:#2c3e50;">Amount ($)</label><input type="number" @bind="newAmount" step="0.01" min="0" style="padding:0.65rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.88rem;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;width:100%;box-sizing:border-box;" /></div>
            @if (!string.IsNullOrEmpty(modalError)) { <p style="font-size:0.8rem;color:#c0392b;margin:0;">@modalError</p> }
            <div style="display:flex;justify-content:flex-end;gap:0.75rem;">
                <button @onclick="CloseModal" style="padding:0.65rem 1.4rem;font-weight:600;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                <button @onclick="SaveProposal" disabled="@isSaving" style="padding:0.65rem 1.5rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;">@(isSaving ? "Submitting..." : "Submit Proposal")</button>
            </div>
        </div>
    </div>
}

@if (showViewModal && viewProposal != null)
{
    var canAct = viewProposal.Status == "Pending" && viewProposal.Level == "Ministry";
    <div style="position:fixed;inset:0;z-index:1000;background:rgba(13,33,55,0.45);display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseViewModal">
        <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:520px;display:flex;flex-direction:column;gap:1.1rem;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#0d2137;margin:0;">Proposal Details — @viewProposal.Status</h2>
            <div>Code: <b>@viewProposal.ProposalCode</b> &middot; Level: @viewProposal.Level &middot; From: @(viewProposal.Level == "Ministry" ? viewProposal.MinistryName : viewProposal.ChurchName)</div>
            <div>Purpose: @viewProposal.Purpose</div>
            @if (!string.IsNullOrEmpty(viewProposal.Description)) { <div>Description: @viewProposal.Description</div> }
            <div>Amount: $@viewProposal.Amount.ToString("N2") &middot; Submitted by: @viewProposal.SubmittedByFirstName @viewProposal.SubmittedByLastName &middot; @viewProposal.CreatedAt.ToString("MMM d, yyyy")</div>
            @if (viewProposal.Status == "Disapproved" || viewProposal.Status == "For Revision") { <div style="background:#fdf5f5;padding:0.55rem 0.8rem;border-radius:8px;">@(viewProposal.Status == "Disapproved" ? "Rejection:" : "Revision:") @viewProposal.RejectionReason</div> }

            @if (actionMode == "reject" || actionMode == "revise")
            {
                <div>
                    <label style="font-weight:600;">@(actionMode == "reject" ? "Rejection Reason" : "Revision Notes")</label>
                    <textarea @bind="actionReason" rows="3" style="padding:0.65rem 0.85rem;border:1.5px solid #d1d9e6;border-radius:8px;width:100%;box-sizing:border-box;"></textarea>
                    @if (!string.IsNullOrEmpty(actionError)) { <p style="color:#c0392b;">@actionError</p> }
                </div>
            }
            @if (actionMode == "approve")
            {
                <div style="background:#f0faf4;border:1.5px solid #a9dfbf;border-radius:10px;padding:1rem;">
                    <label style="font-weight:600;">Select Budget</label>
                    <select @bind="approvalBudgetId" style="padding:0.6rem 0.8rem;border:1.5px solid #d1d9e6;border-radius:8px;width:100%;">
                        <option value="0">— Select church budget —</option>
                        @foreach (var b in churchBudgets)
                        {
                            var alloc = budgetAllocatedMap.TryGetValue(b.BudgetId, out var a) ? a : 0m;
                            <option value="@b.BudgetId">@b.Name (@b.FiscalYear) — Available: $@((b.TotalAmount - alloc).ToString("N0"))</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(approvalError)) { <p style="color:#c0392b;margin:0.5rem 0 0;">@approvalError</p> }
                </div>
            }
            <div style="display:flex;justify-content:space-between;">
                <button @onclick="CloseViewModal" style="padding:0.65rem 1.4rem;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Close</button>
                @if (canAct && actionMode == "")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick="SetRevise"  style="padding:0.65rem 1.1rem;color:#1a5276;background:#e8f4f8;border:none;border-radius:8px;cursor:pointer;">Revise</button>
                        <button @onclick="SetReject"  style="padding:0.65rem 1.1rem;color:#c0392b;background:#fdedec;border:none;border-radius:8px;cursor:pointer;">Reject</button>
                        <button @onclick="SetApprove" style="padding:0.65rem 1.1rem;color:#fff;background:#27ae60;border:none;border-radius:8px;cursor:pointer;">Approve</button>
                    </div>
                }
                @if (actionMode == "reject" || actionMode == "revise")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick="CancelAction" style="padding:0.65rem 1.1rem;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                        <button @onclick="ExecuteAction" disabled="@isActioning" style="padding:0.65rem 1.1rem;color:#fff;background:@(actionMode == "reject" ? "#c0392b" : "#1a5276");border:none;border-radius:8px;cursor:pointer;">@(isActioning ? "..." : actionMode == "reject" ? "Confirm Reject" : "Send for Revision")</button>
                    </div>
                }
                @if (actionMode == "approve")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick="CancelAction" style="padding:0.65rem 1.1rem;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                        <button @onclick="ConfirmApprove" disabled="@(isActioning || approvalBudgetId == 0)" style="padding:0.65rem 1.1rem;color:#fff;background:#27ae60;border:none;border-radius:8px;cursor:pointer;">@(isActioning ? "Approving..." : "Confirm Approve")</button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<BudgetProposalReadDto> allProposals = new();
    private List<Ministry> ministries = new();
    private string activeSubTab = "my";

    private string _searchQuery = "";
    private string searchQuery { get => _searchQuery; set { _searchQuery = value; propPage = 1; } }

    private string _statusFilter = "";
    private string statusFilter { get => _statusFilter; set { _statusFilter = value; propPage = 1; } }

    private int _ministryFilter = 0;
    private int ministryFilter { get => _ministryFilter; set { _ministryFilter = value; propPage = 1; } }
    private int currentProfileId = 0;
    private int currentChurchId = 0;
    private int? currentDistrictId = null;
    private string currentChurchName = "";

    private List<BudgetReadDto> churchBudgets = new();
    private Dictionary<int, decimal> budgetAllocatedMap = new();
    private int approvalBudgetId = 0;
    private string approvalError = "";

    private bool showModal = false;
    private bool isSaving = false;
    private string newPurpose = "";
    private string newDescription = "";
    private decimal newAmount = 0;
    private string modalError = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var accountIdClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (accountIdClaim != null && int.TryParse(accountIdClaim.Value, out int accountId))
        {
            var account = await Db.Accounts.Include(a => a.Church).Include(a => a.Profile).ThenInclude(p => p!.Church).FirstOrDefaultAsync(a => a.AccountId == accountId);
            currentProfileId = account?.ProfileId ?? 0;
            currentChurchId = account?.ChurchId ?? account?.Profile?.ChurchId ?? 0;
            currentDistrictId = account?.Church?.DistrictId ?? account?.Profile?.Church?.DistrictId;
            currentChurchName = account?.Church?.ChurchName ?? account?.Profile?.Church?.ChurchName ?? "—";
        }

        await ReloadProposals();

        var allBudgets = await FinancialApi.GetBudgetsAsync(churchId: currentChurchId);
        churchBudgets = allBudgets.Where(b => b.EndYear >= DateTime.Now.Year).OrderByDescending(b => b.TotalAmount).ToList();

        var budgetIds = churchBudgets.Select(b => b.BudgetId).ToHashSet();
        if (budgetIds.Any())
        {
            var allocs = await FinancialApi.GetAllocationsAsync();
            budgetAllocatedMap = allocs
                .Where(a => a.BudgetId.HasValue && budgetIds.Contains(a.BudgetId.Value))
                .GroupBy(a => a.BudgetId!.Value)
                .ToDictionary(g => g.Key, g => g.Sum(a => a.Allocated));
        }

        ministries = await Db.Set<Ministry>().Where(m => m.Status == "Active").OrderBy(m => m.MinistryName).ToListAsync();
    }

    private async Task ReloadProposals()
    {
        var raw = await FinancialApi.GetProposalsAsync(churchId: currentChurchId > 0 ? currentChurchId : null);
        allProposals = raw.OrderByDescending(p => p.CreatedAt).ToList();
    }

    private void OpenModal() { newPurpose = ""; newDescription = ""; newAmount = 0; modalError = ""; showModal = true; }
    private void CloseModal() { showModal = false; modalError = ""; }

    private async Task SaveProposal()
    {
        modalError = "";
        if (string.IsNullOrWhiteSpace(newPurpose)) { modalError = "Purpose required."; return; }
        if (newAmount <= 0) { modalError = "Amount must be > 0."; return; }
        if (currentProfileId == 0) { modalError = "Cannot identify user."; return; }

        isSaving = true;
        try
        {
            int nextNum = (allProposals.Select(p => p.ProposalCode).Where(c => c.StartsWith("BP-")).Select(c => int.TryParse(c[3..], out var n) ? n : 0).DefaultIfEmpty(1000).Max()) + 1;
            await FinancialApi.CreateProposalAsync(new BudgetProposalCreateDto
            {
                ProposalCode = $"BP-{nextNum}",
                Purpose = newPurpose.Trim(),
                Description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim(),
                MinistryId = null,
                ChurchId = currentChurchId > 0 ? currentChurchId : null,
                DistrictId = currentDistrictId,
                Level = "Local Church",
                Amount = newAmount,
                SubmittedById = currentProfileId
            });
            await ReloadProposals();
            showModal = false;
        }
        catch (Exception ex) { modalError = $"Save failed: {ex.Message}"; }
        isSaving = false;
    }

    private bool showViewModal = false;
    private BudgetProposalReadDto? viewProposal = null;
    private bool isActioning = false;
    private string actionMode = "";
    private string actionReason = "";
    private string actionError = "";

    private void OpenViewModal(BudgetProposalReadDto p) { viewProposal = p; showViewModal = true; actionMode = ""; actionReason = ""; actionError = ""; approvalBudgetId = 0; approvalError = ""; }
    private void CloseViewModal() { showViewModal = false; viewProposal = null; actionMode = ""; actionReason = ""; actionError = ""; approvalBudgetId = 0; approvalError = ""; }
    private void CancelAction() { actionMode = ""; actionReason = ""; actionError = ""; approvalBudgetId = 0; approvalError = ""; }

    private async Task ConfirmApprove()
    {
        if (viewProposal == null) return;
        approvalError = "";
        if (approvalBudgetId == 0) { approvalError = "Select a budget."; return; }

        var selectedBudget = churchBudgets.FirstOrDefault(b => b.BudgetId == approvalBudgetId);
        if (selectedBudget == null) { approvalError = "Invalid budget."; return; }
        var existingAllocated = budgetAllocatedMap.TryGetValue(approvalBudgetId, out var allocated) ? allocated : 0m;
        var available = selectedBudget.TotalAmount - existingAllocated;
        if (viewProposal.Amount > available) { approvalError = $"Insufficient: ${available:N2} available."; return; }

        isActioning = true;
        try
        {
            await FinancialApi.CreateAllocationAsync(new BudgetAllocationWriteDto
            {
                Name = viewProposal.Purpose,
                Allocated = viewProposal.Amount,
                Spent = 0,
                BudgetId = approvalBudgetId
            });
            await FinancialApi.ChangeProposalStatusAsync(viewProposal.ProposalId, new BudgetProposalStatusDto
            {
                Status = "Approved",
                ReviewedById = currentProfileId
            });
            budgetAllocatedMap[approvalBudgetId] = existingAllocated + viewProposal.Amount;
            await ReloadProposals();
            showViewModal = false; viewProposal = null; actionMode = ""; approvalBudgetId = 0;
        }
        catch (Exception ex) { approvalError = $"Approve failed: {ex.Message}"; }
        isActioning = false;
    }

    private async Task ExecuteAction()
    {
        if (viewProposal == null) return;
        if (string.IsNullOrWhiteSpace(actionReason)) { actionError = "Reason required."; return; }
        isActioning = true; actionError = "";
        try
        {
            await FinancialApi.ChangeProposalStatusAsync(viewProposal.ProposalId, new BudgetProposalStatusDto
            {
                Status = actionMode == "reject" ? "Disapproved" : "For Revision",
                ReviewedById = currentProfileId,
                RejectionReason = actionReason.Trim()
            });
            await ReloadProposals();
            showViewModal = false; viewProposal = null; actionMode = ""; actionReason = "";
        }
        catch (Exception ex) { actionError = $"Action failed: {ex.Message}"; }
        isActioning = false;
    }

    private List<BudgetProposalReadDto> myProposals => allProposals.Where(p => p.Level == "Local Church").ToList();
    private List<BudgetProposalReadDto> inboxProposals => allProposals.Where(p => p.Level == "Ministry" && p.Status == "Pending").ToList();

    private List<BudgetProposalReadDto> displayedProposals
    {
        get
        {
            var source = activeSubTab switch
            {
                "my" => myProposals,
                "inbox" => inboxProposals,
                _ => allProposals.Where(p => p.Level == "Ministry").ToList()
            };

            var q = source.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var s = searchQuery.Trim().ToLower();
                q = q.Where(p => p.Purpose.ToLower().Contains(s) || p.ProposalCode.ToLower().Contains(s));
            }
            if (!string.IsNullOrEmpty(statusFilter)) q = q.Where(p => p.Status == statusFilter);
            if (ministryFilter > 0 && (activeSubTab == "inbox" || activeSubTab == "all")) q = q.Where(p => p.MinistryId == ministryFilter);
            return q.ToList();
        }
    }

    private void ShowMy()    { activeSubTab = "my";    propPage = 1; }
    private void ShowInbox() { activeSubTab = "inbox"; propPage = 1; }
    private void ShowAll()   { activeSubTab = "all";   propPage = 1; }

    private void SetRevise()  { actionMode = "revise"; }
    private void SetReject()  { actionMode = "reject"; }
    private void SetApprove() { actionMode = "approve"; approvalBudgetId = 0; approvalError = ""; }

    private int propPage = 1;
    private const int PropPageSize = 10;
    private void ResetPage() => propPage = 1;
    private List<BudgetProposalReadDto> pagedProposals => displayedProposals.Skip((propPage - 1) * PropPageSize).Take(PropPageSize).ToList();
    private int propTotalPages => Math.Max(1, (int)Math.Ceiling((double)displayedProposals.Count / PropPageSize));
}
