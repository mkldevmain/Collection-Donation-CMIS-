@page "/head-pastor/financial/transactions"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Services
@using CMIS.Services.FinancialApi
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject IFinancialApiClient FinancialApi
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Transactions — Head Pastor</PageTitle>

<div class="page-heading"><h1 class="page-title">Financial Management</h1><p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p></div>

<div class="tab-bar">
    <a href="/head-pastor/financial/proposals" data-enhance-nav="false" class="tab">Budget Proposals</a>
    <a href="/head-pastor/financial/transactions" data-enhance-nav="false" class="tab active">Transactions</a>
    <a href="/head-pastor/financial/allocation" data-enhance-nav="false" class="tab">Budget Allocation</a>
    <a href="/head-pastor/financial/monitoring" data-enhance-nav="false" class="tab">Monitoring</a>
    <a href="/head-pastor/financial/reports" data-enhance-nav="false" class="tab">Reports</a>
</div>

<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.85rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;flex:1;min-width:200px;max-width:400px;">
        <input type="text" placeholder="Search transactions..." @bind="searchQuery" @bind:event="oninput" style="border:none;outline:none;background:none;font-size:0.84rem;width:100%;" />
    </div>
    <select @bind="typeFilter" style="padding:0.55rem 0.85rem;font-size:0.84rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;"><option value="">All Types</option><option value="Income">Income</option><option value="Expense">Expense</option></select>
    <select @bind="budgetFilter" style="padding:0.55rem 0.85rem;font-size:0.84rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;"><option value="0">All Allocations</option>@foreach (var a in budgetAllocations.OrderBy(a => a.Name)) { <option value="@a.AllocationId">@a.Name</option> }</select>
    <button @onclick="OpenModal" style="margin-left:auto;padding:0.6rem 1.2rem;font-size:0.82rem;font-weight:700;color:#fff;background:#0d2137;border-radius:8px;border:none;cursor:pointer;">+ Record Transaction</button>
</div>

<div style="background:#fff;border-radius:12px;border:1px solid #e8ecf1;overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:0.84rem;">
        <thead style="background:#f8fafc;"><tr>
            <th style="padding:0.75rem 1rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Date / ID</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Description</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Allocation</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Recorded By</th>
            <th style="padding:0.75rem 1rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Amount</th>
        </tr></thead>
        <tbody>
            @foreach (var t in pagedTransactions)
            {
                <tr style="border-bottom:1px solid #f0f3f6;">
                    <td style="padding:0.85rem 1rem;"><span style="font-weight:600;color:#0d2137;display:block;">@t.TransactionDate.ToString("M/d/yyyy")</span><span style="font-size:0.72rem;color:#8e99a4;">@t.TransactionCode</span></td>
                    <td style="padding:0.85rem 1rem;"><span style="font-weight:600;color:#0d2137;display:block;">@t.Description</span><span style="padding:0.2rem 0.55rem;border-radius:4px;font-size:0.65rem;font-weight:700;@(t.Type == "Income" ? "background:#eafaf1;color:#1e8449;" : "background:#fdedec;color:#c0392b;")">@t.Type.ToUpper()</span></td>
                    <td style="padding:0.85rem 1rem;color:#1a5276;">@t.AllocationName</td>
                    <td style="padding:0.85rem 1rem;color:#2c3e50;">@t.RecordedByName</td>
                    <td style="padding:0.85rem 1rem;text-align:right;font-weight:700;color:@(t.Type == "Income" ? "#1e8449" : "#c0392b");">@(t.Type == "Income" ? "+" : "-")$@t.Amount.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (txTotalPages > 1) { <div style="display:flex;justify-content:center;padding:0.75rem 0;"><MudPagination Count="@txTotalPages" @bind-Selected="txPage" Color="Color.Primary" Size="Size.Small" /></div> }

@if (showModal)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;z-index:1000;" @onclick="CloseModal">
        <div style="background:#fff;border-radius:14px;padding:2rem;width:100%;max-width:480px;" @onclick:stopPropagation="true">
            <h2 style="font-size:1.1rem;font-weight:700;color:#0d2137;margin:0 0 1.25rem;">Record Transaction</h2>
            <div style="display:flex;gap:0.5rem;margin-bottom:1.25rem;">
                <button style="@IncomeToggleStyle" @onclick="SetIncome">Income</button>
                <button style="@ExpenseToggleStyle" @onclick="SetExpense">Expense</button>
            </div>
            <div style="margin-bottom:1rem;"><label style="font-size:0.78rem;font-weight:600;color:#6b7c93;">Amount ($)</label><input type="number" step="0.01" min="0" @bind="newAmount" style="width:100%;padding:0.6rem 0.75rem;font-size:0.84rem;border:1.5px solid #d1d9e6;border-radius:8px;box-sizing:border-box;" /></div>
            <div style="margin-bottom:1rem;"><label style="font-size:0.78rem;font-weight:600;color:#6b7c93;">Description</label><input type="text" @bind="newDescription" style="width:100%;padding:0.6rem 0.75rem;font-size:0.84rem;border:1.5px solid #d1d9e6;border-radius:8px;box-sizing:border-box;" /></div>
            <div style="margin-bottom:1.25rem;"><label style="font-size:0.78rem;font-weight:600;color:#6b7c93;">Budget Allocation</label><select @bind="newBudgetAllocationId" style="width:100%;padding:0.6rem 0.75rem;font-size:0.84rem;border:1.5px solid #d1d9e6;border-radius:8px;background:#fff;box-sizing:border-box;"><option value="0">-- No Allocation --</option>@foreach (var b in budgetAllocations) { <option value="@b.AllocationId">@b.Name</option> }</select></div>
            @if (!string.IsNullOrEmpty(modalError)) { <p style="font-size:0.8rem;color:#c0392b;margin:0 0 0.75rem;">@modalError</p> }
            <div style="display:flex;gap:0.75rem;justify-content:flex-end;">
                <button @onclick="CloseModal" style="padding:0.6rem 1.2rem;font-weight:600;color:#6b7c93;background:#f0f3f6;border:none;border-radius:8px;cursor:pointer;">Cancel</button>
                <button @onclick="SaveTransaction" disabled="@isSaving" style="padding:0.6rem 1.2rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;">@(isSaving ? "Saving..." : "Save")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<TransactionReadDto> allTransactions = new();
    private List<BudgetAllocationReadDto> budgetAllocations = new();
    private string _searchQuery = "";
    private string searchQuery { get => _searchQuery; set { _searchQuery = value; txPage = 1; } }

    private string _typeFilter = "";
    private string typeFilter { get => _typeFilter; set { _typeFilter = value; txPage = 1; } }

    private int _budgetFilter = 0;
    private int budgetFilter { get => _budgetFilter; set { _budgetFilter = value; txPage = 1; } }

    private bool showModal = false;
    private bool isSaving = false;
    private string newType = "Income";
    private decimal newAmount = 0;
    private string newDescription = "";
    private int newBudgetAllocationId = 0;
    private string modalError = "";
    private int currentProfileId = 0;
    private int currentChurchId = 0;
    private HashSet<int> churchProfileIds = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (claim != null && int.TryParse(claim.Value, out int accountId))
        {
            var account = await Db.Accounts.FirstOrDefaultAsync(a => a.AccountId == accountId);
            currentProfileId = account?.ProfileId ?? 0;
            currentChurchId = account?.ChurchId ?? 0;
        }

        if (currentChurchId > 0)
        {
            churchProfileIds = await Db.Profiles.Where(p => p.ChurchId == currentChurchId).Select(p => p.ProfileId).ToHashSetAsync();
        }

        budgetAllocations = (await FinancialApi.GetAllocationsAsync()).OrderBy(b => b.Name).ToList();
        await ReloadTransactions();
    }

    private async Task ReloadTransactions()
    {
        var raw = await FinancialApi.GetTransactionsAsync();
        allTransactions = raw.Where(t => churchProfileIds.Contains(t.RecordedById)).OrderByDescending(t => t.TransactionDate).ThenByDescending(t => t.TransactionCode).ToList();
    }

    private void OpenModal() { newType = "Income"; newAmount = 0; newDescription = ""; newBudgetAllocationId = 0; modalError = ""; showModal = true; }
    private void CloseModal() { showModal = false; modalError = ""; }

    private async Task SaveTransaction()
    {
        modalError = "";
        if (newAmount <= 0) { modalError = "Amount > 0."; return; }
        if (string.IsNullOrWhiteSpace(newDescription)) { modalError = "Description required."; return; }
        if (currentProfileId == 0) { modalError = "Cannot identify user."; return; }

        isSaving = true;
        try
        {
            int nextNum = (allTransactions.Select(t => t.TransactionCode).Where(c => c.StartsWith("TX-")).Select(c => int.TryParse(c[3..], out var n) ? n : 0).DefaultIfEmpty(1000).Max()) + 1;
            await FinancialApi.CreateTransactionAsync(new TransactionWriteDto
            {
                TransactionCode = $"TX-{nextNum}",
                Description = newDescription.Trim(),
                Type = newType,
                BudgetAllocationId = newBudgetAllocationId > 0 ? newBudgetAllocationId : null,
                Amount = newAmount,
                RecordedById = currentProfileId,
                TransactionDate = DateOnly.FromDateTime(DateTime.Today)
            });
            await ReloadTransactions();
            budgetAllocations = (await FinancialApi.GetAllocationsAsync()).OrderBy(b => b.Name).ToList();
            showModal = false;
        }
        catch (Exception ex) { modalError = $"Save failed: {ex.Message}"; }
        isSaving = false;
    }

    private string IncomeToggleStyle => newType == "Income" ? "flex:1;padding:0.55rem;font-size:0.84rem;font-weight:600;border-radius:8px;border:1.5px solid #1e8449;background:#eafaf1;color:#1e8449;cursor:pointer;" : "flex:1;padding:0.55rem;font-size:0.84rem;font-weight:600;border-radius:8px;border:1.5px solid #d1d9e6;background:#fff;color:#6b7c93;cursor:pointer;";
    private string ExpenseToggleStyle => newType == "Expense" ? "flex:1;padding:0.55rem;font-size:0.84rem;font-weight:600;border-radius:8px;border:1.5px solid #c0392b;background:#fdedec;color:#c0392b;cursor:pointer;" : "flex:1;padding:0.55rem;font-size:0.84rem;font-weight:600;border-radius:8px;border:1.5px solid #d1d9e6;background:#fff;color:#6b7c93;cursor:pointer;";

    private List<TransactionReadDto> filteredTransactions
    {
        get
        {
            var q = allTransactions.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var s = searchQuery.Trim().ToLower();
                q = q.Where(t => t.Description.ToLower().Contains(s) || t.TransactionCode.ToLower().Contains(s) || (t.AllocationName ?? "").ToLower().Contains(s));
            }
            if (!string.IsNullOrEmpty(typeFilter)) q = q.Where(t => t.Type == typeFilter);
            if (budgetFilter > 0) q = q.Where(t => t.BudgetAllocationId == budgetFilter);
            return q.ToList();
        }
    }

    private void SetIncome()  { newType = "Income"; }
    private void SetExpense() { newType = "Expense"; }

    private int txPage = 1;
    private const int TxPageSize = 10;
    private void ResetPage() => txPage = 1;
    private List<TransactionReadDto> pagedTransactions => filteredTransactions.Skip((txPage - 1) * TxPageSize).Take(TxPageSize).ToList();
    private int txTotalPages => Math.Max(1, (int)Math.Ceiling((double)filteredTransactions.Count / TxPageSize));
}
