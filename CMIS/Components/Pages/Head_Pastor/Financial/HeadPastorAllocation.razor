@page "/head-pastor/financial/allocation"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Services.FinancialApi
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject IFinancialApiClient FinancialApi
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Budget Allocation — Head Pastor</PageTitle>

<div style="margin-bottom:1.5rem;">
    <h1 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.65rem;color:#0d2137;margin:0 0 0.3rem;">Financial Management</h1>
    <p style="font-family:'Inter',sans-serif;font-size:0.88rem;color:#6b7c93;margin:0;">Manage budgets, track expenses, and monitor financial health.</p>
</div>

<div class="tab-bar">
    <a href="/head-pastor/financial/proposals" data-enhance-nav="false" class="tab">Budget Proposals</a>
    <a href="/head-pastor/financial/transactions" data-enhance-nav="false" class="tab">Transactions</a>
    <a href="/head-pastor/financial/allocation" data-enhance-nav="false" class="tab active">Budget Allocation</a>
    <a href="/head-pastor/financial/monitoring" data-enhance-nav="false" class="tab">Monitoring</a>
    <a href="/head-pastor/financial/reports" data-enhance-nav="false" class="tab">Reports</a>
</div>

<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.25rem;">
    <div>
        <h2 style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.3rem;color:#0d2137;margin:0 0 0.2rem;">Local Church Budgets</h2>
        <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#6b7c93;margin:0;">Budgets and allocations for your church.</p>
    </div>
    <button @onclick="OpenBudgetModal" style="padding:0.6rem 1.2rem;font-family:'Inter',sans-serif;font-size:0.82rem;font-weight:700;color:#fff;background:#0d2137;border:none;border-radius:8px;cursor:pointer;">+ Allocate Budget</button>
</div>

<div style="background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:1.2rem;margin-bottom:1.5rem;">
    <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.05rem;color:#0d2137;margin:0 0 0.75rem;">Budgets (@churchBudgets.Count)</h3>
    <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:0.84rem;">
        <thead><tr>
            <th style="padding:0.6rem 0.8rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Date</th>
            <th style="padding:0.6rem 0.8rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Name</th>
            <th style="padding:0.6rem 0.8rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Fiscal Year</th>
            <th style="padding:0.6rem 0.8rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Total</th>
            <th style="padding:0.6rem 0.8rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Allocated</th>
            <th style="padding:0.6rem 0.8rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Remaining</th>
        </tr></thead>
        <tbody>
            @foreach (var b in churchBudgets)
            {
                var bAllocated = churchAllocs.Where(a => a.BudgetId == b.BudgetId).Sum(a => a.Allocated);
                var bRemaining = b.TotalAmount - bAllocated;
                <tr style="border-bottom:1px solid #f0f3f6;">
                    <td style="padding:0.7rem 0.8rem;color:#8e99a4;">@b.CreatedAt.ToString("M/d/yyyy")</td>
                    <td style="padding:0.7rem 0.8rem;font-weight:600;color:#0d2137;">@b.Name</td>
                    <td style="padding:0.7rem 0.8rem;color:#6b7c93;">@b.FiscalYear</td>
                    <td style="padding:0.7rem 0.8rem;text-align:right;">$@b.TotalAmount.ToString("N0")</td>
                    <td style="padding:0.7rem 0.8rem;text-align:right;color:#1a5276;">$@bAllocated.ToString("N0")</td>
                    <td style="padding:0.7rem 0.8rem;text-align:right;font-weight:700;color:@(bRemaining < 0 ? "#c0392b" : "#1e8449");">$@bRemaining.ToString("N0")</td>
                </tr>
            }
            @if (!churchBudgets.Any()) { <tr><td colspan="6" style="padding:2rem;text-align:center;color:#8e99a4;font-style:italic;">No budgets found.</td></tr> }
        </tbody>
    </table>
</div>

<div style="background:#fff;border:1px solid #e8ecf1;border-radius:12px;padding:1.2rem;">
    <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.05rem;color:#0d2137;margin:0 0 0.75rem;">Budget Allocations (@churchAllocs.Count)</h3>
    <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:0.84rem;">
        <thead><tr>
            <th style="padding:0.6rem 0.8rem;text-align:left;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Name</th>
            <th style="padding:0.6rem 0.8rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Allocated</th>
            <th style="padding:0.6rem 0.8rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Spent</th>
            <th style="padding:0.6rem 0.8rem;text-align:right;font-size:0.72rem;color:#6b7c93;border-bottom:1px solid #e8ecf1;">Balance</th>
        </tr></thead>
        <tbody>
            @foreach (var a in churchAllocs)
            {
                var balance = a.Allocated - a.Spent;
                <tr style="border-bottom:1px solid #f0f3f6;">
                    <td style="padding:0.7rem 0.8rem;font-weight:600;color:#0d2137;">@a.Name</td>
                    <td style="padding:0.7rem 0.8rem;text-align:right;">$@a.Allocated.ToString("N0")</td>
                    <td style="padding:0.7rem 0.8rem;text-align:right;color:#c0392b;">$@a.Spent.ToString("N0")</td>
                    <td style="padding:0.7rem 0.8rem;text-align:right;font-weight:700;color:@(balance < 0 ? "#c0392b" : "#1e8449");">$@balance.ToString("N0")</td>
                </tr>
            }
            @if (!churchAllocs.Any()) { <tr><td colspan="4" style="padding:2rem;text-align:center;color:#8e99a4;font-style:italic;">No allocations.</td></tr> }
        </tbody>
    </table>
</div>

@if (showBudgetModal)
{
    <div class="modal-overlay" @onclick="CloseBudgetModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h2 class="modal-title">Allocate Budget</h2>
            <div class="modal-field"><label class="modal-label">Budget</label><select class="modal-input" @bind="budgetModalBudgetId"><option value="0">— Select —</option>@foreach (var b in churchBudgets.Where(b => b.EndYear >= DateTime.Now.Year)) { <option value="@b.BudgetId">@b.Name (@b.FiscalYear)</option> }</select></div>
            <div class="modal-field"><label class="modal-label">Allocation Name</label><input type="text" class="modal-input" @bind="budgetModalName" /></div>
            <div class="modal-field"><label class="modal-label">Amount ($)</label><input type="number" class="modal-input" step="0.01" @bind="budgetModalAmount" /></div>
            @if (!string.IsNullOrEmpty(budgetModalError)) { <p class="modal-error">@budgetModalError</p> }
            <div class="modal-actions">
                <button class="modal-btn-cancel" @onclick="CloseBudgetModal">Cancel</button>
                <button class="modal-btn-save" @onclick="SaveAllocateBudget" disabled="@isSavingBudget">@(isSavingBudget ? "Saving..." : "Allocate")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<BudgetReadDto> churchBudgets = new();
    private List<BudgetAllocationReadDto> churchAllocs = new();
    private int currentChurchId = 0;

    private bool showBudgetModal = false;
    private bool isSavingBudget = false;
    private int budgetModalBudgetId = 0;
    private string budgetModalName = "";
    private decimal budgetModalAmount = 0;
    private string budgetModalError = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (claim != null && int.TryParse(claim.Value, out int accountId))
        {
            var account = await Db.Accounts.FirstOrDefaultAsync(a => a.AccountId == accountId);
            currentChurchId = account?.ChurchId ?? 0;
        }
        await ReloadData();
    }

    private void OpenBudgetModal() { budgetModalBudgetId = 0; budgetModalName = ""; budgetModalAmount = 0; budgetModalError = ""; showBudgetModal = true; }
    private void CloseBudgetModal() { showBudgetModal = false; budgetModalError = ""; }

    private async Task SaveAllocateBudget()
    {
        budgetModalError = "";
        if (budgetModalBudgetId == 0) { budgetModalError = "Select a budget."; return; }
        if (string.IsNullOrWhiteSpace(budgetModalName)) { budgetModalError = "Name required."; return; }
        if (budgetModalAmount <= 0) { budgetModalError = "Amount > 0."; return; }

        isSavingBudget = true;
        try
        {
            await FinancialApi.CreateAllocationAsync(new BudgetAllocationWriteDto
            {
                Name = budgetModalName.Trim(),
                Allocated = budgetModalAmount,
                Spent = 0,
                BudgetId = budgetModalBudgetId
            });
            await ReloadData();
            showBudgetModal = false;
        }
        catch (Exception ex) { budgetModalError = $"Save failed: {ex.Message}"; }
        isSavingBudget = false;
    }

    private async Task ReloadData()
    {
        var allBudgets = await FinancialApi.GetBudgetsAsync(churchId: currentChurchId);
        churchBudgets = allBudgets.OrderByDescending(b => b.TotalAmount).ToList();

        var budgetIds = churchBudgets.Select(b => b.BudgetId).ToHashSet();
        if (budgetIds.Any())
        {
            var allAllocs = await FinancialApi.GetAllocationsAsync();
            churchAllocs = allAllocs.Where(a => a.BudgetId.HasValue && budgetIds.Contains(a.BudgetId.Value)).OrderBy(a => a.Name).ToList();
        }
        else { churchAllocs = new(); }
    }
}
