    // ── Helpers ──
    string GetServiceIcon(string t) => t?.ToLower() switch {
        "baptism"=>"fas fa-water","counsel"=>"fas fa-comments","wedding"=>"fas fa-heart",
        "child dedication"=>"fas fa-baby","funeral"=>"fas fa-cross",_=>"fas fa-concierge-bell"
    };
    string FormatType(string t) => t switch {
        "baptism"=>"Baptism","counsel"=>"Counsel","wedding"=>"Wedding",
        "child dedication"=>"Child Dedication","funeral"=>"Funeral",_=>"All"
    };
    string FormatStatus(string s) => s switch {
        "in progress"=>"In Progress","scheduled"=>"Scheduled","rescheduled"=>"Rescheduled",
        "cancelled"=>"Cancelled","complete"=>"Complete",_=>s
    };
    string GetStatusClass(string s) => s switch {
        "in progress"=>"status-inprogress","scheduled"=>"status-scheduled","rescheduled"=>"status-rescheduled",
        "cancelled"=>"status-cancelled","complete"=>"status-complete",_=>""
    };
    string FormatDate(string? d) => DateTime.TryParse(d, out var dt) ? dt.ToString("MMM dd, yyyy") : "None";
    string FormatKey(string k) => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(k.Replace("-"," "));

    string ServiceManagementIcon(string t) => t switch {
        "baptism" => "fa-water", "counsel" => "fa-hands-helping", "wedding" => "fa-rings", "child dedication" => "fa-baby", "funeral" => "fa-cross", _ => "fa-calendar-check"
    };

    bool CanSchedule(string t) => t switch {
        "baptism" => b_date.HasValue && b_start.HasValue && b_end.HasValue && !string.IsNullOrWhiteSpace(b_venue),
        "counsel" => c_date.HasValue && c_start.HasValue && c_end.HasValue,
        "wedding" => w_date.HasValue && w_start.HasValue && w_end.HasValue && !string.IsNullOrWhiteSpace(w_venue) && w_cert && w_rec && w_aff,
        "child dedication" => cd_date.HasValue && cd_start.HasValue && cd_end.HasValue && !string.IsNullOrWhiteSpace(cd_venue) && cd_birthCert,
        "funeral" => f_date.HasValue && f_start.HasValue && f_end.HasValue && !string.IsNullOrWhiteSpace(f_venue),
        _ => false
    };

    string StatusClass(string s) => string.IsNullOrWhiteSpace(s) ? "" : "status-" + s.Replace(" ", "");

    string GetFormValidationMessage() {
        switch(selectedType) {
            case "baptism":
                if (pickedProfile == null) return "Person Being Baptized profile is required.";
                break;
            case "counsel":
                if (pickedProfile == null) return "Counselee profile is required.";
                break;
            case "wedding":
                if (w_spouses.Count != 2) return "Exactly 2 spouse profiles (Bride and Groom) are required.";
                bool hasMale = w_spouses.Any(s => s.Profile.Sex.Equals("Male", StringComparison.OrdinalIgnoreCase));
                bool hasFemale = w_spouses.Any(s => s.Profile.Sex.Equals("Female", StringComparison.OrdinalIgnoreCase));
                if (!hasMale || !hasFemale) return "Spouses must include one Male (Groom) and one Female (Bride).";
                break;
            case "child dedication":
                if (pickedChild == null) return "Child profile is required.";
                if (cd_parents.Count == 0) return "At least one Parent profile is required.";
                break;
            case "funeral":
                if (pickedDeceased == null) return "Deceased profile is required.";
                if (pickedKin == null) return "Kin / Next of Kin profile is required.";
                break;
        }
        return "";
    }
    
    bool IsFormValid() => string.IsNullOrEmpty(GetFormValidationMessage());

    bool IsScheduleConflict(DateTime? targetDate, TimeOnly? targetStart, TimeOnly? targetEnd) {
        if (!targetDate.HasValue || !targetStart.HasValue || !targetEnd.HasValue) return false;
        
        var dateStr = targetDate.Value.ToString("yyyy-MM-dd");
        
        // Check services
        foreach(var s in AllServices) {
            if (s.Status != "scheduled" && s.Status != "rescheduled") continue;
            if (s.ImplementationDate != dateStr) continue;
            
            if (TimeOnly.TryParse(s.StartTime, out var sStart) && TimeOnly.TryParse(s.EndTime, out var sEnd)) {
                if (targetStart.Value < sEnd && targetEnd.Value > sStart) return true;
            }
        }
        
        // Check appointments
        foreach(var a in AllAppointments) {
            if (a.Status != "scheduled" && a.Status != "rescheduled") continue;
            if (a.ImplementationDate != dateStr) continue;
            
            if (DateTime.TryParse(a.StartTime, out var aStartDt) && DateTime.TryParse(a.EndTime, out var aEndDt)) {
                var aStart = TimeOnly.FromDateTime(aStartDt);
                var aEnd = TimeOnly.FromDateTime(aEndDt);
                if (targetStart.Value < aEnd && targetEnd.Value > aStart) return true;
            }
        }
        return false;
    }

