@page "/head-pastor/schedule"
@layout CMIS.Components.Layout.DashboardLayout
@rendermode InteractiveServer
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text

<PageTitle>Configure Schedule — CMIS Portal</PageTitle>
<HeadContent>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</HeadContent>

<div class="config-schedule">

    <!-- TAB HEADER -->
    <div class="tab-bar">
        <button class="tab-btn @(activeTab == "weekly" ? "active" : "")" @onclick='() => activeTab = "weekly"'>
            <i class="fas fa-calendar-week"></i> Weekly Schedule
        </button>
        <button class="tab-btn @(activeTab == "dayex" ? "active" : "")" @onclick='() => activeTab = "dayex"'>
            <i class="fas fa-calendar-times"></i> Day Exceptions
        </button>
        <button class="tab-btn @(activeTab == "timeex" ? "active" : "")" @onclick='() => activeTab = "timeex"'>
            <i class="fas fa-clock"></i> Time Exceptions
        </button>
    </div>

    @if (!string.IsNullOrEmpty(globalMsg))
    {
        <div class="global-msg @(globalSuccess ? "success" : "error")">
            <i class="fas @(globalSuccess ? "fa-check-circle" : "fa-exclamation-circle")"></i> @globalMsg
        </div>
    }

    <!-- ═══════ TAB 1: WEEKLY SCHEDULE ═══════ -->
    @if (activeTab == "weekly")
    {
        <div class="section-card glass-card">
            <div class="section-header">
                <div>
                    <h3><i class="fas fa-calendar-week"></i> Weekly Availability</h3>
                    <p class="section-desc">Configure which days and times you're available for appointments.</p>
                </div>
                <button class="btn-add" @onclick="() => { showWeeklyForm = true; editingWeeklyId = null; wfDay = 0; wfStart = new TimeOnly(9,0); wfEnd = new TimeOnly(10,0); wfActive = true; }">
                    <i class="fas fa-plus"></i> Add Slot
                </button>
            </div>

            @if (showWeeklyForm)
            {
                <div class="inline-form">
                    <h4>@(editingWeeklyId.HasValue ? "Edit Slot" : "New Time Slot")</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Day</label>
                            <select @bind="wfDay" class="form-control">
                                @for (int i = 0; i < 7; i++)
                                {
                                    var idx = i;
                                    <option value="@idx">@DayName(idx)</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Start Time</label>
                            <input type="time" @bind="wfStart" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>End Time</label>
                            <input type="time" @bind="wfEnd" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Active</label>
                            <label class="toggle-label">
                                <input type="checkbox" @bind="wfActive" />
                                <span class="toggle-text">@(wfActive ? "Yes" : "No")</span>
                            </label>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" @onclick="SaveWeeklyConfig" disabled="@isSaving"><i class="fas fa-check"></i> Save</button>
                        <button class="btn-cancel" @onclick="() => showWeeklyForm = false"><i class="fas fa-times"></i> Cancel</button>
                    </div>
                </div>
            }

            @if (isLoadingWeekly)
            {
                <div class="loading-state"><div class="spinner"></div><p>Loading...</p></div>
            }
            else
            {
                <div class="weekly-grid">
                    @for (int d = 0; d < 7; d++)
                    {
                        var day = d;
                        var daySlots = weeklyConfigs.Where(c => c.Day == day).ToList();
                        <div class="day-column" style="display: flex; flex-direction: column;">
                            <div class="day-header">@DayName(day)</div>
                            @if (daySlots.Count == 0)
                            {
                                <div class="empty-slot" style="flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center;"><i class="fas fa-moon"></i> No slots</div>
                            }
                            else
                            {
                                @foreach (var slot in daySlots)
                                {
                                    <div class="slot-card @(slot.IsActive == true ? "active" : "inactive")">
                                        <div class="slot-time">
                                            <i class="far fa-clock"></i>
                                            @FormatTime(slot.StartTime) — @FormatTime(slot.EndTime)
                                        </div>
                                        <div class="slot-status">
                                            <span class="status-badge @(slot.IsActive == true ? "badge-active" : "badge-inactive")">
                                                @(slot.IsActive == true ? "Active" : "Inactive")
                                            </span>
                                        </div>
                                        <div class="slot-actions">
                                            <button class="btn-icon toggle" title="Toggle" @onclick="() => ToggleWeekly(slot)"><i class="fas fa-power-off"></i></button>
                                            <button class="btn-icon edit" title="Edit" @onclick="() => EditWeekly(slot)"><i class="fas fa-pen"></i></button>
                                            <button class="btn-icon delete" title="Delete" @onclick="() => DeleteWeekly(slot.WeeklyConfigId)"><i class="fas fa-trash"></i></button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- ═══════ TAB 2: DAY EXCEPTIONS ═══════ -->
    @if (activeTab == "dayex")
    {
        <div class="section-card glass-card">
            <div class="section-header">
                <div>
                    <h3><i class="fas fa-calendar-times"></i> Day Exceptions</h3>
                    <p class="section-desc">Block entire days when you are unavailable (holidays, vacations, etc.).</p>
                </div>
                <button class="btn-add" @onclick="OpenDayExForm">
                    <i class="fas fa-plus"></i> Add Exception
                </button>
            </div>

            @if (showDayExForm)
            {
                <div class="inline-form">
                    <h4>@(editingDayExId.HasValue ? "Edit Day Exception" : "New Day Exception")</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Date</label>
                            <input type="date" @bind="dfDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Title</label>
                            <input type="text" @bind="dfTitle" placeholder="e.g. National Holiday" class="form-control" />
                        </div>
                        <div class="form-group wide">
                            <label>Description</label>
                            <input type="text" @bind="dfDesc" placeholder="Optional details..." class="form-control" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" @onclick="SaveDayException" disabled="@isSaving"><i class="fas fa-check"></i> Save</button>
                        <button class="btn-cancel" @onclick="() => showDayExForm = false"><i class="fas fa-times"></i> Cancel</button>
                    </div>
                </div>
            }

            @if (isLoadingDayEx)
            {
                <div class="loading-state"><div class="spinner"></div><p>Loading...</p></div>
            }
            else if (dayExceptions.Count == 0)
            {
                <div class="empty-state"><i class="fas fa-check-double"></i><p>No day exceptions configured.</p></div>
            }
            else
            {
                <div class="exception-list">
                    @foreach (var ex in dayExceptions)
                    {
                        <div class="exception-card">
                            <div class="exc-icon day-icon"><i class="fas fa-ban"></i></div>
                            <div class="exc-info">
                                <div class="exc-title">@(string.IsNullOrEmpty(ex.Title) ? "Blocked Day" : ex.Title)</div>
                                <div class="exc-date"><i class="fas fa-calendar-day"></i> @ex.Date.ToString("MMM dd, yyyy (dddd)")</div>
                                @if (!string.IsNullOrEmpty(ex.Description))
                                {
                                    <div class="exc-desc">@ex.Description</div>
                                }
                            </div>
                            <div class="exc-actions">
                                <button class="btn-icon edit" @onclick="() => EditDayException(ex)"><i class="fas fa-pen"></i></button>
                                <button class="btn-icon delete" @onclick="() => DeleteDayException(ex.DayExceptionId)"><i class="fas fa-trash"></i></button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- ═══════ TAB 3: TIME EXCEPTIONS ═══════ -->
    @if (activeTab == "timeex")
    {
        <div class="section-card glass-card">
            <div class="section-header">
                <div>
                    <h3><i class="fas fa-clock"></i> Time Exceptions</h3>
                    <p class="section-desc">Block specific time slots on specific dates.</p>
                </div>
                <button class="btn-add" @onclick="() => { showTimeExForm = true; editingTimeExId = null; tfDate = DateTime.Today; tfStart = new TimeOnly(9,0); tfEnd = new TimeOnly(10,0); }">
                    <i class="fas fa-plus"></i> Add Exception
                </button>
            </div>

            @if (showTimeExForm)
            {
                <div class="inline-form">
                    <h4>@(editingTimeExId.HasValue ? "Edit Time Exception" : "New Time Exception")</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Date</label>
                            <input type="date" @bind="tfDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Start Time</label>
                            <input type="time" @bind="tfStart" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>End Time</label>
                            <input type="time" @bind="tfEnd" class="form-control" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-save" @onclick="SaveTimeException" disabled="@isSaving"><i class="fas fa-check"></i> Save</button>
                        <button class="btn-cancel" @onclick="() => showTimeExForm = false"><i class="fas fa-times"></i> Cancel</button>
                    </div>
                </div>
            }

            @if (isLoadingTimeEx)
            {
                <div class="loading-state"><div class="spinner"></div><p>Loading...</p></div>
            }
            else if (timeExceptions.Count == 0)
            {
                <div class="empty-state"><i class="fas fa-check-double"></i><p>No time exceptions configured.</p></div>
            }
            else
            {
                <div class="exception-list">
                    @foreach (var ex in timeExceptions)
                    {
                        <div class="exception-card">
                            <div class="exc-icon time-icon"><i class="far fa-clock"></i></div>
                            <div class="exc-info">
                                <div class="exc-title">Blocked Time</div>
                                <div class="exc-date"><i class="fas fa-calendar-day"></i> @ex.Date.ToString("MMM dd, yyyy (dddd)")</div>
                                <div class="exc-time"><i class="far fa-clock"></i> @FormatTime(ex.StartTime) — @FormatTime(ex.EndTime)</div>
                            </div>
                            <div class="exc-actions">
                                <button class="btn-icon edit" @onclick="() => EditTimeException(ex)"><i class="fas fa-pen"></i></button>
                                <button class="btn-icon delete" @onclick="() => DeleteTimeException(ex.TimeExceptionId)"><i class="fas fa-trash"></i></button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private const string ApiBase = "http://localhost:5096";
    private const int PastorAccountId = 3;

    private string activeTab = "weekly";
    private string? globalMsg;
    private bool globalSuccess;
    private bool isSaving;

    // ── Weekly Config ──
    private List<WeeklyConfigDto> weeklyConfigs = new();
    private bool isLoadingWeekly = true;
    private bool showWeeklyForm;
    private int? editingWeeklyId;
    private int wfDay;
    private TimeOnly wfStart = new(9, 0);
    private TimeOnly wfEnd = new(10, 0);
    private bool wfActive = true;

    // ── Day Exceptions ──
    private List<DayExceptionDto> dayExceptions = new();
    private bool isLoadingDayEx = true;
    private bool showDayExForm;
    private int? editingDayExId;
    private DateTime dfDate = DateTime.Today;
    private string dfTitle = "";
    private string dfDesc = "";

    // ── Time Exceptions ──
    private List<TimeExceptionDto> timeExceptions = new();
    private bool isLoadingTimeEx = true;
    private bool showTimeExForm;
    private int? editingTimeExId;
    private DateTime tfDate = DateTime.Today;
    private TimeOnly tfStart = new(9, 0);
    private TimeOnly tfEnd = new(10, 0);

    private static readonly string[] DayNames = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
    private string DayName(int d) => d >= 0 && d < 7 ? DayNames[d] : "?";
    private string FormatTime(TimeSpan ts) => DateTime.Today.Add(ts).ToString("hh:mm tt");

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadWeeklyConfigs(), LoadDayExceptions(), LoadTimeExceptions());
    }

    // ════════════════════════════════════════
    //  WEEKLY CONFIG CRUD
    // ════════════════════════════════════════
    private async Task LoadWeeklyConfigs()
    {
        isLoadingWeekly = true;
        try
        {
            using var http = new HttpClient();
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            weeklyConfigs = await http.GetFromJsonAsync<List<WeeklyConfigDto>>($"{ApiBase}/WeeklyConfig/{PastorAccountId}", opts) ?? new();
        }
        catch { globalMsg = "Failed to load weekly configs."; globalSuccess = false; }
        finally { isLoadingWeekly = false; }
    }

    private async Task SaveWeeklyConfig()
    {
        if (wfStart >= wfEnd) { globalMsg = "Start time must be before end time."; globalSuccess = false; return; }
        isSaving = true; globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            var payload = new { accountId = PastorAccountId, day = wfDay, startTime = wfStart.ToString("HH:mm:ss"), endTime = wfEnd.ToString("HH:mm:ss"), isActive = wfActive };
            var json = new StringContent(JsonSerializer.Serialize(payload), Encoding.UTF8, "application/json");

            HttpResponseMessage response;
            if (editingWeeklyId.HasValue)
                response = await http.PutAsync($"{ApiBase}/WeeklyConfig/update/{editingWeeklyId.Value}", json);
            else
                response = await http.PostAsync($"{ApiBase}/WeeklyConfig/create", json);

            if (response.IsSuccessStatusCode)
            {
                globalMsg = editingWeeklyId.HasValue ? "Slot updated!" : "Slot created!"; globalSuccess = true;
                showWeeklyForm = false;
                await LoadWeeklyConfigs();
            }
            else
            {
                globalMsg = await ParseApiError(response);
                globalSuccess = false;
            }
        }
        catch { globalMsg = "Save failed."; globalSuccess = false; }
        finally { isSaving = false; StateHasChanged(); }
    }

    private void EditWeekly(WeeklyConfigDto slot)
    {
        editingWeeklyId = slot.WeeklyConfigId; wfDay = slot.Day;
        wfStart = TimeOnly.FromTimeSpan(slot.StartTime); wfEnd = TimeOnly.FromTimeSpan(slot.EndTime);
        wfActive = slot.IsActive ?? true; showWeeklyForm = true;
    }

    private async Task ToggleWeekly(WeeklyConfigDto slot)
    {
        globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            var payload = new { accountId = PastorAccountId, day = slot.Day, startTime = slot.StartTime.ToString(@"hh\:mm\:ss"), endTime = slot.EndTime.ToString(@"hh\:mm\:ss"), isActive = !(slot.IsActive ?? true) };
            var json = new StringContent(JsonSerializer.Serialize(payload), Encoding.UTF8, "application/json");
            await http.PutAsync($"{ApiBase}/WeeklyConfig/update/{slot.WeeklyConfigId}", json);
            globalMsg = $"Slot {(payload.isActive ? "activated" : "deactivated")}!"; globalSuccess = true;
            await LoadWeeklyConfigs();
        }
        catch { globalMsg = "Toggle failed."; globalSuccess = false; }
        StateHasChanged();
    }

    private async Task DeleteWeekly(int id)
    {
        globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            await http.DeleteAsync($"{ApiBase}/WeeklyConfig/delete/{id}");
            globalMsg = "Slot deleted."; globalSuccess = true;
            await LoadWeeklyConfigs();
        }
        catch { globalMsg = "Delete failed."; globalSuccess = false; }
        StateHasChanged();
    }

    // ════════════════════════════════════════
    //  DAY EXCEPTION CRUD
    // ════════════════════════════════════════
    private async Task LoadDayExceptions()
    {
        isLoadingDayEx = true;
        try
        {
            using var http = new HttpClient();
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            dayExceptions = await http.GetFromJsonAsync<List<DayExceptionDto>>($"{ApiBase}/DayException/{PastorAccountId}", opts) ?? new();
        }
        catch { globalMsg = "Failed to load day exceptions."; globalSuccess = false; }
        finally { isLoadingDayEx = false; }
    }

    private async Task SaveDayException()
    {
        if (string.IsNullOrWhiteSpace(dfTitle)) { globalMsg = "Title is required."; globalSuccess = false; return; }
        if (dfDate.Date < DateTime.Today) { globalMsg = "Cannot block a past date."; globalSuccess = false; return; }
        isSaving = true; globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            var payload = new { accountId = PastorAccountId, date = dfDate.ToString("yyyy-MM-dd"), title = dfTitle, description = dfDesc };
            var json = new StringContent(JsonSerializer.Serialize(payload), Encoding.UTF8, "application/json");

            HttpResponseMessage response;
            if (editingDayExId.HasValue)
                response = await http.PutAsync($"{ApiBase}/DayException/update/{editingDayExId.Value}", json);
            else
                response = await http.PostAsync($"{ApiBase}/DayException/create", json);

            if (response.IsSuccessStatusCode)
            {
                globalMsg = editingDayExId.HasValue ? "Day exception updated!" : "Day exception created!"; globalSuccess = true;
                showDayExForm = false;
                await LoadDayExceptions();
            }
            else
            {
                globalMsg = await ParseApiError(response);
                globalSuccess = false;
            }
        }
        catch { globalMsg = "Save failed."; globalSuccess = false; }
        finally { isSaving = false; StateHasChanged(); }
    }

    private void OpenDayExForm()
    {
        showDayExForm = true; editingDayExId = null;
        dfDate = DateTime.Today; dfTitle = ""; dfDesc = "";
    }

    private void EditDayException(DayExceptionDto ex)
    {
        editingDayExId = ex.DayExceptionId; dfDate = ex.Date;
        dfTitle = ex.Title ?? ""; dfDesc = ex.Description ?? "";
        showDayExForm = true;
    }

    private async Task DeleteDayException(int id)
    {
        globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            await http.DeleteAsync($"{ApiBase}/DayException/delete/{id}");
            globalMsg = "Day exception deleted."; globalSuccess = true;
            await LoadDayExceptions();
        }
        catch { globalMsg = "Delete failed."; globalSuccess = false; }
        StateHasChanged();
    }

    // ════════════════════════════════════════
    //  TIME EXCEPTION CRUD
    // ════════════════════════════════════════
    private async Task LoadTimeExceptions()
    {
        isLoadingTimeEx = true;
        try
        {
            using var http = new HttpClient();
            var opts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            timeExceptions = await http.GetFromJsonAsync<List<TimeExceptionDto>>($"{ApiBase}/TimeException/{PastorAccountId}", opts) ?? new();
        }
        catch { globalMsg = "Failed to load time exceptions."; globalSuccess = false; }
        finally { isLoadingTimeEx = false; }
    }

    private async Task SaveTimeException()
    {
        if (tfStart >= tfEnd) { globalMsg = "Start time must be before end time."; globalSuccess = false; return; }
        if (tfDate.Date < DateTime.Today) { globalMsg = "Cannot block a past date."; globalSuccess = false; return; }
        isSaving = true; globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            var payload = new { accountId = PastorAccountId, date = tfDate.ToString("yyyy-MM-dd"), startTime = tfStart.ToString("HH:mm:ss"), endTime = tfEnd.ToString("HH:mm:ss") };
            var json = new StringContent(JsonSerializer.Serialize(payload), Encoding.UTF8, "application/json");

            HttpResponseMessage response;
            if (editingTimeExId.HasValue)
                response = await http.PutAsync($"{ApiBase}/TimeException/update/{editingTimeExId.Value}", json);
            else
                response = await http.PostAsync($"{ApiBase}/TimeException/create", json);

            if (response.IsSuccessStatusCode)
            {
                globalMsg = editingTimeExId.HasValue ? "Time exception updated!" : "Time exception created!"; globalSuccess = true;
                showTimeExForm = false;
                await LoadTimeExceptions();
            }
            else
            {
                globalMsg = await ParseApiError(response);
                globalSuccess = false;
            }
        }
        catch { globalMsg = "Save failed."; globalSuccess = false; }
        finally { isSaving = false; StateHasChanged(); }
    }

    private void EditTimeException(TimeExceptionDto ex)
    {
        editingTimeExId = ex.TimeExceptionId; tfDate = ex.Date;
        tfStart = TimeOnly.FromTimeSpan(ex.StartTime); tfEnd = TimeOnly.FromTimeSpan(ex.EndTime);
        showTimeExForm = true;
    }

    private async Task DeleteTimeException(int id)
    {
        globalMsg = null; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            await http.DeleteAsync($"{ApiBase}/TimeException/delete/{id}");
            globalMsg = "Time exception deleted."; globalSuccess = true;
            await LoadTimeExceptions();
        }
        catch { globalMsg = "Delete failed."; globalSuccess = false; }
        StateHasChanged();
    }

    // ── Helpers ──
    private async Task<string> ParseApiError(HttpResponseMessage response)
    {
        var error = await response.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(error)) return "Save failed.";
        if (error.StartsWith("{"))
        {
            try
            {
                using var doc = JsonDocument.Parse(error);
                if (doc.RootElement.TryGetProperty("detail", out var detail) && detail.ValueKind == JsonValueKind.String)
                    return detail.GetString() ?? "Save failed.";
                if (doc.RootElement.TryGetProperty("title", out var title) && title.ValueKind == JsonValueKind.String)
                    return title.GetString() ?? "Save failed.";
            }
            catch { }
        }
        return error;
    }

    // ── DTOs ──
    public class WeeklyConfigDto
    {
        public int WeeklyConfigId { get; set; }
        public int AccountId { get; set; }
        public int Day { get; set; }
        public TimeSpan StartTime { get; set; }
        public TimeSpan EndTime { get; set; }
        public bool? IsActive { get; set; }
    }
    public class DayExceptionDto
    {
        public int DayExceptionId { get; set; }
        public int AccountId { get; set; }
        public DateTime Date { get; set; }
        public string? Title { get; set; }
        public string? Description { get; set; }
    }
    public class TimeExceptionDto
    {
        public int TimeExceptionId { get; set; }
        public int AccountId { get; set; }
        public DateTime Date { get; set; }
        public TimeSpan StartTime { get; set; }
        public TimeSpan EndTime { get; set; }
    }
}
