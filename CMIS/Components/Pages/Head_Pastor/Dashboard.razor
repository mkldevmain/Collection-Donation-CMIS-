@page "/head-pastor"
@layout CMIS.Components.Layout.DashboardLayout
@rendermode InteractiveServer

<PageTitle>Dashboard — CMIS Portal</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Welcome back. Here's an overview of your area.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:#e8f4f8;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a5276" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Financial Management</span>
            <a href="/head-pastor/financial/proposals" class="stat-value" style="font-size:0.85rem;color:#1a5276;text-decoration:none;">Open &rarr;</a>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#eafaf1;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1e8449" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Collection and Donation</span>
            <a href="/head-pastor/collections" class="stat-value" style="font-size:0.85rem;color:#1e8449;text-decoration:none;">Open &rarr;</a>
        </div>
    </div>
</div>
