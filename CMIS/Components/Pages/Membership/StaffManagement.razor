@page "/staff"
@page "/{RoleSlug}/staff"
@layout AdminLayout
@using CMIS.Data
@using CMIS.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthState
@rendermode InteractiveServer

<PageTitle>Staff Management</PageTitle>

<div style="padding: 2rem; font-family: 'Inter', sans-serif;">
    <CMIS.Components.Shared.PageHeader Title="Staff Management" />

    @* ──────────── CONTENT CARD ──────────── *@
    <div style="padding: 1.5rem; background-color: white; border-radius: 12px;">

        @* ── Toolbar: Search + Sort + Add ── *@
        <div style="display: flex; gap: 0.7rem; margin-bottom: 1.5rem;">
            <div style="position: relative; width: 100%;">
                
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"
                     style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%);">
                    <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" placeholder="Search for Staff" @bind="searchQuery" @bind:event="oninput" class="searchinput" style="padding-left: 2.4rem;" />
            </div>

            <div style="display: flex; gap: 0.7rem;">
                <select @bind="currentSortOption" class="filter-select">
                    <option value="Date Added (Newest)">Date Added (Newest)</option>
                    <option value="Date Added (Oldest)">Date Added (Oldest)</option>
                    <option value="Name (A-Z)">Name (A-Z)</option>
                    <option value="Name (Z-A)">Name (Z-A)</option>
                </select>
                <button type="button" @onclick="OpenModal" class="mmbr-createbutton">
                    <span style="margin-right: 0.3rem;">+</span> Add New Staff
                </button>
            </div>
        </div>

        @* ── Table Header ── *@
        <div class="table-header">
            <div class="col-name">Name</div>
            <div class="col-chapter">Assigned Chapter</div>
            <div class="col-role">Role</div>
            <div class="col-date">Date Added</div>
            <div class="col-actions"></div>
        </div>

        @* ── Table Body / Rows ── *@
        @if (isLoading)
        {
            <div style="text-align: center; padding: 3rem; color: #94a3b8;">
                <p>Loading staff members...</p>
            </div>
        }
        else if (!FilteredStaff.Any())
        {
            <div style="text-align: center; padding: 3rem; color: #94a3b8;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" style="margin-bottom: 0.8rem;">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <p style="margin: 0; font-weight: 600; color: #64748b;">No staff members found</p>
                <p style="margin: 0.3rem 0 0; font-size: 0.85rem;">Try adjusting your search or add a new staff member.</p>
            </div>
        }
        else
        {
            @foreach (var staff in FilteredStaff)
            {
                <div class="table-row">
                    <div class="col-name" style="display: flex; align-items: center; gap: 0.8rem;">
                        <img src="https://i.pravatar.cc/150?img=@(staff.ProfileId % 70)" alt="avatar"
                             style="width: 36px; height: 36px; border-radius: 10px; object-fit: cover; border: 2px solid #e8ecf1;" />
                        <span style="font-family: 'Inter', sans-serif; font-weight: 400; font-size: 1rem; color: #0d2137;">@staff.FullName</span>
                    </div>
                    <div class="col-chapter" style="font-family: 'Inter', sans-serif; font-weight: 400; font-size: 1rem; color: #6b7c93;">@staff.AssignedChurch</div>
                    <div class="col-role" style="font-family: 'Inter', sans-serif; font-weight: 400; font-size: 1rem; color: #6b7c93;">@staff.RoleName</div>
                    <div class="col-date" style="font-family: 'Inter', sans-serif; font-weight: 400; font-size: 1rem; color: #6b7c93;">@staff.DateAdded</div>
                    <div class="col-actions" style="position: relative;">
                        <button type="button" @onclick="() => ToggleActionMenu(staff.ProfileId)" style="background: none; border: none; cursor: pointer; color: #94a3b8; padding: 0.3rem; font-size: 1.2rem; letter-spacing: 2px;">
                            •••
                        </button>
                        
                        @if (openActionMenuId == staff.ProfileId)
                        {
                            <div style="position: absolute; right: 30px; top: 10px; background: white; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); z-index: 10; min-width: 150px; padding: 0.5rem 0;">
                                <div style="padding: 0.5rem 1rem; font-size: 0.85rem; cursor: pointer; color: #0d2137;" @onclick="() => OpenEditModal(staff.ProfileId)" onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='transparent'">
                                    Edit Staff
                                </div>
                                <div style="padding: 0.5rem 1rem; font-size: 0.85rem; cursor: pointer; color: #ef4444;" @onclick="() => RemoveAccess(staff.ProfileId)" onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='transparent'">
                                    Remove Access
                                </div>
                            </div>
                            <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 5;" @onclick="() => openActionMenuId = null"></div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (isModalOpen)
{
    <CMIS.Components.Dialogs.StaffCreationDialog EditProfileId="editProfileId" OnClose="CloseModal" OnSuccess="HandleSuccess" />
}

@code {
    [Parameter] public string? RoleSlug { get; set; }
    private bool isModalOpen = false;
    private bool isLoading = true;
    private string searchQuery = "";
    private string currentSortOption = "Date Added (Newest)";
    private int? openActionMenuId = null;
    private int? editProfileId = null;
    private bool isBOD = false;
    private int? userChurchId = null;

    private List<StaffView> staffList = new();

    // ────── View Model for the table ──────
    private class StaffView
    {
        public int ProfileId { get; set; }
        public string FullName { get; set; } = "";
        public string AssignedChurch { get; set; } = "—";
        public string RoleName { get; set; } = "—";
        public string DateAdded { get; set; } = "—";
        public DateTime? RawDate { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        // 1. THE NATIVE SECURITY BOUNCER
        // If they aren't logged in, OR they aren't a BOD / Head Pastor, kick them to login.
        if (!user.Identity?.IsAuthenticated ?? true || 
            (!user.IsInRole("Board of Directors") && !user.IsInRole("Head Pastor")))
        {
            Nav.NavigateTo("/login");
            return; // This stops the rest of the page from loading
        }

        // 2. LOAD PAGE DATA FOR AUTHORIZED USERS
        isBOD = user.IsInRole("Board of Directors");
        var churchClaim = user.FindFirst("ChurchId")?.Value;
        
        if (int.TryParse(churchClaim, out var cid))
        {
            userChurchId = cid;
        }

        await LoadStaff();
    }

    private async Task LoadStaff()
    {
        isLoading = true;

        if (!isBOD && !userChurchId.HasValue)
        {
            staffList = new();
            isLoading = false;
            return;
        }

        // Query: Profiles that HAVE an Account (i.e. staff/users) and are not Inactive
        var query = Db.Profiles
            .Where(p => p.Account != null && 
                        p.ProfileStatus != "Inactive" && 
                        p.Account.RoleId != 6);

        // Apply scoping filter if not BOD
        if (!isBOD && userChurchId.HasValue)
        {
            query = query.Where(p => p.ChurchId == userChurchId.Value || 
                                     p.LeadershipAssignments.Any(la => la.ChurchId == userChurchId.Value && la.Status == "Active"));
        }

        var data = await query
            .Include(p => p.Account!)
                .ThenInclude(a => a.Role)
            .Include(p => p.LeadershipAssignments.Where(la => la.Status == "Active"))
                .ThenInclude(la => la.Church)
            .OrderByDescending(p => p.Account!.CreatedAt)
            .ToListAsync();

        staffList = data.Select(p => new StaffView
        {
            ProfileId = p.ProfileId,
            FullName = $"{p.FirstName} {p.MiddleName} {p.LastName}".Replace("  ", " ").Trim(),
            AssignedChurch = p.LeadershipAssignments
                .Where(la => la.Church != null)
                .Select(la => la.Church!.ChurchName)
                .FirstOrDefault() ?? "—",
            RoleName = p.Account?.Role?.RoleName ?? "—",
            DateAdded = p.Account?.CreatedAt?.ToString("MM/dd/yyyy") ?? "—",
            RawDate = p.Account?.CreatedAt
        }).ToList();

        isLoading = false;
    }

    private IEnumerable<StaffView> FilteredStaff
    {
        get
        {
            var result = string.IsNullOrWhiteSpace(searchQuery)
                ? staffList
                : staffList.Where(s =>
                    s.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    s.AssignedChurch.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    s.RoleName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

            return currentSortOption switch
            {
                "Date Added (Oldest)" => result.OrderBy(s => s.RawDate),
                "Name (A-Z)" => result.OrderBy(s => s.FullName),
                "Name (Z-A)" => result.OrderByDescending(s => s.FullName),
                _ => result.OrderByDescending(s => s.RawDate) // "Date Added (Newest)"
            };
        }
    }

    private void ToggleActionMenu(int id)
    {
        if (openActionMenuId == id) openActionMenuId = null;
        else openActionMenuId = id;
    }

    private void OpenModal()
    {
        editProfileId = null;
        isModalOpen = true;
    }

    private void OpenEditModal(int profileId)
    {
        editProfileId = profileId;
        isModalOpen = true;
        openActionMenuId = null;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        editProfileId = null;
    }

    private async Task RemoveAccess(int profileId)
    {
        openActionMenuId = null;
        
        var profile = await Db.Profiles
            .Include(p => p.Account)
            .Include(p => p.LeadershipAssignments)
            .FirstOrDefaultAsync(p => p.ProfileId == profileId);

        if (profile != null)
        {
            profile.ProfileStatus = "Inactive";
            
            if (profile.Account != null)
            {
                profile.Account.Status = "Inactive";
            }

            foreach (var assignment in profile.LeadershipAssignments)
            {
                assignment.Status = "Inactive";
            }

            await Db.SaveChangesAsync();
            await LoadStaff();
            StateHasChanged();
        }
    }

    private async Task HandleSuccess()
    {
        isModalOpen = false;
        editProfileId = null;
        await LoadStaff();
        StateHasChanged();
    }
}
