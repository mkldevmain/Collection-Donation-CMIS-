@page "/leadership-council/financial/monitoring"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Services.FinancialApi
@inject IFinancialApiClient FinancialApi
@rendermode InteractiveServer

<PageTitle>Monitoring — Leadership Council</PageTitle>

<div class="page-heading">
    <h1 class="page-title">Financial Management</h1>
    <p class="page-subtitle">Manage budgets, track expenses, and monitor financial health.</p>
</div>

<!-- Tab Bar -->
<div class="tab-bar">
    <a href="/leadership-council/financial/proposals" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Budget Proposals</a>
    <a href="/leadership-council/financial/transactions" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Transactions</a>
    <a href="/leadership-council/financial/allocation" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Budget Allocation</a>
    <a href="/leadership-council/financial/monitoring" data-enhance-nav="false" class="tab active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> Monitoring</a>
    <a href="/leadership-council/financial/reports" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Reports</a>
</div>

<!-- Filters -->
<div style="background:#fff;border:1px solid #e8ecf1;border-radius:10px;padding:1rem 1.2rem;margin-bottom:1.5rem;">
    <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.6rem;font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7c93;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        Filters
    </div>
    <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:flex-end;">
        <div style="flex:1;min-width:110px;">
            <label style="display:block;font-family:'Inter',sans-serif;font-size:0.68rem;color:#8e99a4;margin-bottom:0.2rem;">Level</label>
            <select @bind="filterLevel" @bind:after="OnLevelFilterChanged" style="width:100%;padding:0.45rem 0.6rem;border:1.5px solid #d1d9e6;border-radius:6px;font-family:'Inter',sans-serif;font-size:0.8rem;color:#2c3e50;outline:none;background:#fff;">
                <option value="">All Levels</option>
                @foreach (var l in levelOptions) { <option value="@l">@l</option> }
            </select>
        </div>
        <div style="flex:1;min-width:140px;">
            <label style="display:block;font-family:'Inter',sans-serif;font-size:0.68rem;color:#8e99a4;margin-bottom:0.2rem;">Budget</label>
            <select @bind="filterBudget" @bind:after="OnBudgetFilterChanged" style="width:100%;padding:0.45rem 0.6rem;border:1.5px solid #d1d9e6;border-radius:6px;font-family:'Inter',sans-serif;font-size:0.8rem;color:#2c3e50;outline:none;background:#fff;">
                <option value="">All Budgets</option>
                @foreach (var b in filteredBudgetNames) { <option value="@b">@b</option> }
            </select>
        </div>
        <div style="flex:1;min-width:140px;">
            <label style="display:block;font-family:'Inter',sans-serif;font-size:0.68rem;color:#8e99a4;margin-bottom:0.2rem;">Allocated Budget</label>
            <select @bind="filterAllocation" style="width:100%;padding:0.45rem 0.6rem;border:1.5px solid #d1d9e6;border-radius:6px;font-family:'Inter',sans-serif;font-size:0.8rem;color:#2c3e50;outline:none;background:#fff;">
                <option value="">All</option>
                @foreach (var a in filteredAllocationNames) { <option value="@a">@a</option> }
            </select>
        </div>
        <div style="display:flex;align-items:flex-end;padding-bottom:0.05rem;">
            <button @onclick="ResetFilters" style="background:none;border:none;font-family:'Inter',sans-serif;font-size:0.75rem;color:#1a5276;cursor:pointer;text-decoration:underline;white-space:nowrap;">Reset</button>
        </div>
    </div>
</div>

<!-- Wallet Widget -->
@{
    var currentYear = DateTime.Now.Year;
    var currentBudgetIds = displayBudgets.Where(b => b.StartYear <= currentYear && b.EndYear >= currentYear).Select(b => b.BudgetId).ToHashSet();
    var walletTotal = displayBudgets.Where(b => b.StartYear <= currentYear && b.EndYear >= currentYear).Sum(b => b.TotalAmount);
    var walletAllocated = displayAllocations.Where(a => a.BudgetId.HasValue && currentBudgetIds.Contains(a.BudgetId.Value)).Sum(a => a.Allocated);
    var walletSpent = displayAllocations.Where(a => a.BudgetId.HasValue && currentBudgetIds.Contains(a.BudgetId.Value)).Sum(a => a.Spent);
    var expiredBudgetIds = displayBudgets.Where(b => b.EndYear < currentYear).Select(b => b.BudgetId).ToHashSet();
    var priorYearSpent = displayAllocations.Where(a => a.BudgetId.HasValue && expiredBudgetIds.Contains(a.BudgetId.Value)).Sum(a => a.Spent);
    var priorYearRemaining = displayBudgets.Where(b => b.EndYear < currentYear).Sum(b => b.TotalAmount) - priorYearSpent;
    var walletAvailable = walletTotal - walletSpent + priorYearRemaining;
    var activeAllocsDisplay = displayAllocations.Where(a => a.BudgetId.HasValue && currentBudgetIds.Contains(a.BudgetId.Value));
}
<div style="background:linear-gradient(135deg,#0d2137 0%,#1a3a5c 55%,#0d3060 100%);border-radius:16px;padding:1.6rem 2rem;margin-bottom:2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;box-shadow:0 4px 24px rgba(13,33,55,0.2);position:relative;overflow:hidden;">
    <div style="position:absolute;right:-40px;top:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,0.05);pointer-events:none;"></div>
    <div style="position:absolute;right:60px;bottom:-60px;width:140px;height:140px;border-radius:50%;background:rgba(255,255,255,0.04);pointer-events:none;"></div>
    <div style="display:flex;align-items:center;gap:1.5rem;flex:1;min-width:0;position:relative;">
        <div style="background:rgba(255,255,255,0.12);border-radius:14px;padding:1rem;flex-shrink:0;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3.5v3M8 3.5v3"/><circle cx="17" cy="14" r="1.5" fill="white" stroke="none"/></svg>
        </div>
        <div>
            <div style="font-family:'Inter',sans-serif;font-size:0.68rem;font-weight:600;color:rgba(255,255,255,0.55);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.35rem;">Available Balance</div>
            <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:2.2rem;color:#fff;line-height:1;">$@walletAvailable.ToString("N0")</div>
            @if (priorYearRemaining > 0)
            {
                <div style="font-family:'Inter',sans-serif;font-size:0.7rem;color:rgba(150,220,180,0.85);margin-top:0.25rem;">+ $@priorYearRemaining.ToString("N0") prior year rollover</div>
            }
            <div style="font-family:'Inter',sans-serif;font-size:0.72rem;color:rgba(255,255,255,0.45);margin-top:0.25rem;">@DateTime.Now.ToString("MMMM yyyy")</div>
        </div>
    </div>
    <div style="width:1px;height:70px;background:rgba(255,255,255,0.15);flex-shrink:0;position:relative;"></div>
    <div style="display:flex;gap:2.5rem;flex-shrink:0;position:relative;">
        <div style="text-align:center;">
            <div style="font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:0.35rem;">Total Budget</div>
            <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.2rem;color:#fff;">$@walletTotal.ToString("N0")</div>
        </div>
        <div style="text-align:center;">
            <div style="font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:0.35rem;">Allocated</div>
            <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.2rem;color:#f0c040;">$@walletAllocated.ToString("N0")</div>
        </div>
        <div style="text-align:center;">
            <div style="font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:0.35rem;">Spent</div>
            <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.2rem;color:#e07070;">$@walletSpent.ToString("N0")</div>
        </div>
    </div>
</div>

<!-- Budgets -->
@if (displayBudgets.Any())
{
    <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:2px solid #e8ecf1;">Budgets</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.1rem;margin-bottom:2rem;">
        @foreach (var b in displayBudgets.Where(b => b.EndYear >= DateTime.Now.Year))
        {
            var bAllocated = displayAllocations.Where(a => a.BudgetId == b.BudgetId).Sum(a => a.Allocated);
            var bPct = b.TotalAmount > 0 ? (double)(bAllocated / b.TotalAmount) * 100 : 0;
            var bAccent = bPct > 75 ? "#c0392b" : bPct > 50 ? "#e67e22" : "#27ae60";
            var bRemaining = b.TotalAmount - bAllocated;
            <div style="background:#fff;border:1px solid #e2e8f0;border-top:4px solid @bAccent;border-radius:12px;padding:1.2rem 1.3rem;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
                    <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin:0;">@b.Name</h3>
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#6b7c93;">Allocated</span>
                    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;color:#0d2137;">@(bPct.ToString("F1"))%</span>
                </div>
                <div style="height:7px;background:#e8ecf1;border-radius:4px;overflow:hidden;margin-bottom:1.1rem;">
                    <div style="height:100%;width:@(Math.Min(bPct,100).ToString("F0"))%;background:@bAccent;border-radius:4px;"></div>
                </div>
                <div style="display:flex;gap:2rem;margin-bottom:1rem;">
                    <div>
                        <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Total Amount</span>
                        <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.05rem;color:#0d2137;">$@b.TotalAmount.ToString("N0")</span>
                    </div>
                    <div>
                        <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Allocated</span>
                        <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.05rem;color:#0d2137;">$@bAllocated.ToString("N0")</span>
                    </div>
                </div>
                <div style="background:#f5f7fa;border:1px solid #e8ecf1;border-radius:8px;padding:0.65rem 0.9rem;">
                    <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Remaining Balance</span>
                    <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;color:#0d2137;">$@bRemaining.ToString("N0")</span>
                </div>
            </div>
        }
    </div>
}

<!-- Budget Allocations -->
@if (activeAllocsDisplay.Any())
{
    <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin-bottom:1rem;padding-bottom:0.5rem;border-bottom:2px solid #e8ecf1;">Budget Allocations</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.1rem;margin-bottom:2rem;">
        @foreach (var a in activeAllocsDisplay)
        {
            var pct = a.Utilization;
            var accent = pct > 75 ? "#c0392b" : pct > 50 ? "#e67e22" : "#27ae60";
            <div style="background:#fff;border:1px solid #e2e8f0;border-top:4px solid @accent;border-radius:12px;padding:1.2rem 1.3rem;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
                    <h3 style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1rem;color:#0d2137;margin:0;">@a.Name</h3>
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#27ae60" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.4rem;">
                    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#6b7c93;">Utilization</span>
                    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;color:#0d2137;">@(pct.ToString("F1"))%</span>
                </div>
                <div style="height:7px;background:#e8ecf1;border-radius:4px;overflow:hidden;margin-bottom:1.1rem;">
                    <div style="height:100%;width:@(Math.Min(pct,100).ToString("F0"))%;background:@accent;border-radius:4px;"></div>
                </div>
                <div style="display:flex;gap:2rem;margin-bottom:1rem;">
                    <div>
                        <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Allocated</span>
                        <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.05rem;color:#0d2137;">$@a.Allocated.ToString("N0")</span>
                    </div>
                    <div>
                        <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Spent</span>
                        <span style="font-family:'Outfit',sans-serif;font-weight:700;font-size:1.05rem;color:#0d2137;">$@a.Spent.ToString("N0")</span>
                    </div>
                </div>
                <div style="background:#f5f7fa;border:1px solid #e8ecf1;border-radius:8px;padding:0.65rem 0.9rem;">
                    <span style="display:block;font-family:'Inter',sans-serif;font-size:0.65rem;font-weight:600;color:#8e99a4;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Remaining Balance</span>
                    <span style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;color:#0d2137;">$@a.RemainingBalance.ToString("N0")</span>
                </div>
            </div>
        }
    </div>
}

@if (!displayBudgets.Any() && !displayAllocations.Any())
{
    <div style="text-align:center;padding:3rem;color:#6b7c93;font-family:'Inter',sans-serif;font-size:0.9rem;">No financial data found for the selected filters.</div>
}

@code {
    private List<BudgetReadDto> allBudgets = new();
    private List<BudgetAllocationReadDto> allAllocations = new();

    private string filterLevel = "National";
    private string filterBudget = "";
    private string filterAllocation = "";

    protected override async Task OnInitializedAsync()
    {
        allBudgets = (await FinancialApi.GetBudgetsAsync()).OrderByDescending(b => b.TotalAmount).ToList();
        allAllocations = (await FinancialApi.GetAllocationsAsync()).OrderBy(a => a.Name).ToList();
    }

    private IEnumerable<string> levelOptions => allBudgets
        .Select(b => b.Level).Where(l => !string.IsNullOrEmpty(l))
        .Distinct().OrderBy(l => l);

    private IEnumerable<string> filteredBudgetNames => allBudgets
        .Where(b => string.IsNullOrEmpty(filterLevel) || b.Level == filterLevel)
        .Select(b => b.Name).Where(n => !string.IsNullOrEmpty(n))
        .Distinct().OrderBy(n => n);

    private IEnumerable<string> filteredAllocationNames
    {
        get
        {
            var budgetIds = displayBudgets.Select(b => b.BudgetId).ToHashSet();
            return allAllocations
                .Where(a => a.BudgetId.HasValue && budgetIds.Contains(a.BudgetId.Value))
                .Select(a => a.Name).Where(n => !string.IsNullOrEmpty(n))
                .Distinct().OrderBy(n => n);
        }
    }

    private List<BudgetReadDto> displayBudgets
    {
        get
        {
            var q = allBudgets.AsEnumerable();
            if (!string.IsNullOrEmpty(filterLevel)) q = q.Where(b => b.Level == filterLevel);
            if (!string.IsNullOrEmpty(filterBudget)) q = q.Where(b => b.Name == filterBudget);
            return q.ToList();
        }
    }

    private List<BudgetAllocationReadDto> displayAllocations
    {
        get
        {
            var budgetIds = displayBudgets.Select(b => b.BudgetId).ToHashSet();
            var q = allAllocations.Where(a => a.BudgetId.HasValue && budgetIds.Contains(a.BudgetId.Value));
            if (!string.IsNullOrEmpty(filterAllocation)) q = q.Where(a => a.Name == filterAllocation);
            return q.ToList();
        }
    }

    private void OnLevelFilterChanged() { filterBudget = ""; filterAllocation = ""; }
    private void OnBudgetFilterChanged() { filterAllocation = ""; }
    private void ResetFilters() { filterLevel = "National"; filterBudget = ""; filterAllocation = ""; }
}
