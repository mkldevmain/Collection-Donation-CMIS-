@page "/leadership-council/financial/proposals"
@layout CMIS.Components.Layout.DashboardLayout
@using CMIS.Data
@using CMIS.Models
@using CMIS.Services
@using CMIS.Services.FinancialApi
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject IFinancialApiClient FinancialApi
@inject CustomAuthStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Budget Proposals — Leadership Council</PageTitle>

<div class="page-heading"><h1 class="page-title">Financial Management</h1><p class="page-subtitle">Approve district and local-church budget proposals from the national budget.</p></div>

<div class="tab-bar">
    <a href="/leadership-council/financial/proposals" data-enhance-nav="false" class="tab active"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Budget Proposals</a>
    <a href="/leadership-council/financial/transactions" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Transactions</a>
    <a href="/leadership-council/financial/allocation" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Budget Allocation</a>
    <a href="/leadership-council/financial/monitoring" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> Monitoring</a>
    <a href="/leadership-council/financial/reports" data-enhance-nav="false" class="tab"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg> Reports</a>
</div>

<div style="display:flex;gap:0.5rem;margin-bottom:1rem;">
    <button @onclick='() => { activeSubTab = "inbox"; ResetPage(); }' style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.5rem 1rem;font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;border-radius:20px;border:1.5px solid @(activeSubTab == "inbox" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "inbox" ? "#0d2137" : "#fff");color:@(activeSubTab == "inbox" ? "#fff" : "#6b7c93");cursor:pointer;">
        Approval Inbox <span style="background:@(activeSubTab == "inbox" ? "rgba(255,255,255,0.2)" : "#e8ecf1");padding:0.1rem 0.45rem;border-radius:10px;font-size:0.68rem;">@approvalInbox.Count</span>
    </button>
    <button @onclick='() => { activeSubTab = "all"; ResetPage(); }' style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.5rem 1rem;font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;border-radius:20px;border:1.5px solid @(activeSubTab == "all" ? "#0d2137" : "#d1d9e6");background:@(activeSubTab == "all" ? "#0d2137" : "#fff");color:@(activeSubTab == "all" ? "#fff" : "#6b7c93");cursor:pointer;">
        All Proposals <span style="background:@(activeSubTab == "all" ? "rgba(255,255,255,0.2)" : "#e8ecf1");padding:0.1rem 0.45rem;border-radius:10px;font-size:0.68rem;">@allProposals.Count(p => p.Level != "Ministry")</span>
    </button>
</div>

<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.55rem 0.85rem;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;flex:1;min-width:200px;max-width:400px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search proposals..." @bind="searchQuery" @bind:event="oninput" @bind:after="ResetPage" style="border:none;outline:none;background:none;font-family:'Inter',sans-serif;font-size:0.84rem;color:#1a1a2e;width:100%;" />
    </div>
    <select @bind="statusFilter" @bind:after="ResetPage" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:120px;"><option value="">All Statuses</option><option value="Pending">Pending</option><option value="Approved">Approved</option><option value="Disapproved">Disapproved</option><option value="For Revision">For Revision</option></select>
    <select @bind="levelFilter" @bind:after="ResetPage" style="padding:0.55rem 0.85rem;font-family:'Inter',sans-serif;font-size:0.84rem;color:#2c3e50;background:#fff;border:1.5px solid #d1d9e6;border-radius:8px;outline:none;min-width:120px;"><option value="">All Levels</option><option value="Local Church">Local Church</option><option value="District">District</option></select>
</div>

<div style="background:#fff;border-radius:12px;border:1px solid #e8ecf1;overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:0.84rem;table-layout:fixed;">
        <colgroup><col style="width:12%"/><col style="width:25%"/><col style="width:10%"/><col style="width:15%"/><col style="width:12%"/><col style="width:14%"/><col style="width:12%"/></colgroup>
        <thead style="background:#f8fafc;"><tr>
            <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">ID</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Purpose</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Level</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">From</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Amount</th>
            <th style="padding:0.75rem 1rem;text-align:left;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Status</th>
            <th style="padding:0.75rem 1rem;text-align:center;font-weight:600;font-size:0.72rem;color:#6b7c93;text-transform:uppercase;border-bottom:1px solid #e8ecf1;">Actions</th>
        </tr></thead>
        <tbody>
            @foreach (var p in pagedProposals)
            {
                var statusColor = p.Status == "Approved" ? "#27ae60" : p.Status == "Disapproved" ? "#c0392b" : p.Status == "For Revision" ? "#1a5276" : "#e67e22";
                var statusBg = p.Status == "Approved" ? "#eafaf1" : p.Status == "Disapproved" ? "#fdedec" : p.Status == "For Revision" ? "#e8f4f8" : "#fef9e7";
                <tr style="border-bottom:1px solid #f0f3f6;">
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">@p.ProposalCode</td>
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">@p.Purpose</td>
                    <td style="padding:0.85rem 1rem;">@p.Level</td>
                    <td style="padding:0.85rem 1rem;">@(p.Level == "District" ? p.DistrictName : p.ChurchName ?? "—")</td>
                    <td style="padding:0.85rem 1rem;font-weight:600;color:#0d2137;">$@p.Amount.ToString("N0")</td>
                    <td style="padding:0.85rem 1rem;"><span style="padding:0.2rem 0.6rem;border-radius:12px;font-size:0.72rem;font-weight:600;background:@statusBg;color:@statusColor;">@p.Status</span></td>
                    <td style="padding:0.85rem 1rem;text-align:center;"><svg @onclick="() => OpenViewModal(p)" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8e99a4" stroke-width="2" style="cursor:pointer;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (propTotalPages > 1)
{
    <div style="display:flex;justify-content:center;padding:0.75rem 0 0.25rem;">
        <MudPagination Count="@propTotalPages" @bind-Selected="propPage" Color="Color.Primary" Size="Size.Small" />
    </div>
}

@if (showViewModal && viewProposal != null)
{
    var canAct = viewProposal.Status == "Pending" && (viewProposal.Level == "Local Church" || viewProposal.Level == "District");
    <div style="position:fixed;inset:0;z-index:1000;background:rgba(13,33,55,0.45);display:flex;align-items:center;justify-content:center;padding:1rem;" @onclick="CloseViewModal">
        <div style="background:#fff;border-radius:16px;padding:2rem;width:100%;max-width:520px;display:flex;flex-direction:column;gap:1.1rem;max-height:90vh;overflow-y:auto;" @onclick:stopPropagation="true">
            <h2 style="font-weight:800;font-size:1.25rem;color:#0d2137;margin:0;">Proposal Details — @viewProposal.Status</h2>
            <div>Code: <b>@viewProposal.ProposalCode</b> &middot; Level: @viewProposal.Level</div>
            <div>From: @(viewProposal.Level == "Local Church" ? viewProposal.ChurchName : viewProposal.DistrictName)</div>
            <div>Purpose: @viewProposal.Purpose</div>
            @if (!string.IsNullOrEmpty(viewProposal.Description)) { <div>Description: @viewProposal.Description</div> }
            <div>Amount: $@viewProposal.Amount.ToString("N2") &middot; Submitted: @viewProposal.SubmittedByFirstName @viewProposal.SubmittedByLastName &middot; @viewProposal.CreatedAt.ToString("MMM d, yyyy")</div>
            @if (viewProposal.Status == "Disapproved" || viewProposal.Status == "For Revision") { <div style="background:#fdf5f5;padding:0.55rem 0.8rem;border-radius:8px;">@(viewProposal.Status == "Disapproved" ? "Rejection:" : "Revision:") @viewProposal.RejectionReason</div> }

            @if (actionMode == "reject" || actionMode == "revise")
            {
                <div><label style="font-weight:600;">@(actionMode == "reject" ? "Rejection Reason" : "Revision Notes")</label><textarea @bind="actionReason" rows="3" style="padding:0.65rem 0.85rem;border:1.5px solid #d1d9e6;border-radius:8px;width:100%;box-sizing:border-box;"></textarea>@if (!string.IsNullOrEmpty(actionError)) { <p style="color:#c0392b;">@actionError</p> }</div>
            }
            @if (actionMode == "approve")
            {
                <div style="background:#f0faf4;border:1.5px solid #a9dfbf;border-radius:10px;padding:1rem;">
                    <label style="font-weight:600;">Select National Budget</label>
                    <select @bind="approvalBudgetId" style="padding:0.6rem 0.8rem;border:1.5px solid #d1d9e6;border-radius:8px;width:100%;">
                        <option value="0">— Select national budget —</option>
                        @foreach (var b in nationalBudgets)
                        {
                            var alloc = nationalAllocatedMap.TryGetValue(b.BudgetId, out var a) ? a : 0m;
                            <option value="@b.BudgetId">@b.Name (@b.FiscalYear) — Available: $@((b.TotalAmount - alloc).ToString("N0"))</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(approvalError)) { <p style="color:#c0392b;margin:0.5rem 0 0;">@approvalError</p> }
                </div>
            }
            <div style="display:flex;justify-content:space-between;">
                <button @onclick="CloseViewModal" style="padding:0.65rem 1.4rem;color:#6b7c93;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Close</button>
                @if (canAct && actionMode == "")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick='() => actionMode = "revise"' style="padding:0.65rem 1.1rem;color:#1a5276;background:#e8f4f8;border:none;border-radius:8px;cursor:pointer;">Revise</button>
                        <button @onclick='() => actionMode = "reject"' style="padding:0.65rem 1.1rem;color:#c0392b;background:#fdedec;border:none;border-radius:8px;cursor:pointer;">Reject</button>
                        <button @onclick='() => { actionMode = "approve"; approvalBudgetId = 0; approvalError = ""; }' style="padding:0.65rem 1.1rem;color:#fff;background:#27ae60;border:none;border-radius:8px;cursor:pointer;">Approve</button>
                    </div>
                }
                @if (actionMode == "reject" || actionMode == "revise")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick="CancelAction" style="padding:0.65rem 1.1rem;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                        <button @onclick="ExecuteAction" disabled="@isActioning" style="padding:0.65rem 1.1rem;color:#fff;background:@(actionMode == "reject" ? "#c0392b" : "#1a5276");border:none;border-radius:8px;cursor:pointer;">@(isActioning ? "..." : actionMode == "reject" ? "Confirm Reject" : "Send for Revision")</button>
                    </div>
                }
                @if (actionMode == "approve")
                {
                    <div style="display:flex;gap:0.5rem;">
                        <button @onclick="CancelAction" style="padding:0.65rem 1.1rem;background:none;border:1.5px solid #d1d9e6;border-radius:8px;cursor:pointer;">Cancel</button>
                        <button @onclick="ConfirmApprove" disabled="@(isActioning || approvalBudgetId == 0)" style="padding:0.65rem 1.1rem;color:#fff;background:#27ae60;border:none;border-radius:8px;cursor:pointer;">@(isActioning ? "Approving..." : "Confirm Approve")</button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<BudgetProposalReadDto> allProposals = new();
    private List<BudgetReadDto> nationalBudgets = new();
    private Dictionary<int, decimal> nationalAllocatedMap = new();
    private string activeSubTab = "inbox";
    private string searchQuery = "";
    private string statusFilter = "";
    private string levelFilter = "";
    private int currentProfileId = 0;

    private int approvalBudgetId = 0;
    private string approvalError = "";
    private bool showViewModal = false;
    private BudgetProposalReadDto? viewProposal = null;
    private bool isActioning = false;
    private string actionMode = "";
    private string actionReason = "";
    private string actionError = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (claim != null && int.TryParse(claim.Value, out int accountId))
        {
            var account = await Db.Accounts.FirstOrDefaultAsync(a => a.AccountId == accountId);
            currentProfileId = account?.ProfileId ?? 0;
        }
        await ReloadProposals();
        var allBudgets = await FinancialApi.GetBudgetsAsync(level: "National");
        nationalBudgets = allBudgets.Where(b => b.EndYear >= DateTime.Now.Year).OrderByDescending(b => b.TotalAmount).ToList();
        var natIds = nationalBudgets.Select(b => b.BudgetId).ToHashSet();
        if (natIds.Any())
        {
            var allocs = await FinancialApi.GetAllocationsAsync();
            nationalAllocatedMap = allocs
                .Where(a => a.BudgetId.HasValue && natIds.Contains(a.BudgetId.Value))
                .GroupBy(a => a.BudgetId!.Value)
                .ToDictionary(g => g.Key, g => g.Sum(a => a.Allocated));
        }
    }

    private async Task ReloadProposals()
    {
        var raw = await FinancialApi.GetProposalsAsync();
        allProposals = raw.OrderByDescending(p => p.CreatedAt).ToList();
    }

    private void OpenViewModal(BudgetProposalReadDto p) { viewProposal = p; showViewModal = true; actionMode = ""; actionReason = ""; actionError = ""; approvalBudgetId = 0; approvalError = ""; }
    private void CloseViewModal() { showViewModal = false; viewProposal = null; actionMode = ""; actionReason = ""; actionError = ""; approvalBudgetId = 0; approvalError = ""; }
    private void CancelAction() { actionMode = ""; actionReason = ""; actionError = ""; approvalBudgetId = 0; approvalError = ""; }
    private void ResetPage() => propPage = 1;

    private async Task ConfirmApprove()
    {
        if (viewProposal == null) return;
        approvalError = "";
        if (approvalBudgetId == 0) { approvalError = "Select a national budget."; return; }

        var nationalBudget = nationalBudgets.FirstOrDefault(b => b.BudgetId == approvalBudgetId);
        if (nationalBudget == null) { approvalError = "Invalid budget."; return; }
        var existingAllocated = nationalAllocatedMap.TryGetValue(approvalBudgetId, out var used) ? used : 0m;
        var available = nationalBudget.TotalAmount - existingAllocated;
        if (viewProposal.Amount > available) { approvalError = $"Insufficient: ${available:N2} available."; return; }

        isActioning = true;
        try
        {
            var entityName = viewProposal.Level == "Local Church" ? viewProposal.ChurchName ?? "Church" : viewProposal.DistrictName ?? "District";

            await FinancialApi.CreateBudgetAsync(new BudgetWriteDto
            {
                Name = viewProposal.Purpose,
                Level = viewProposal.Level == "Local Church" ? "Church" : "District",
                TotalAmount = viewProposal.Amount,
                ChurchId = viewProposal.Level == "Local Church" ? viewProposal.ChurchId : null,
                DistrictId = viewProposal.Level == "District" ? viewProposal.DistrictId : null,
                StartYear = nationalBudget.StartYear,
                EndYear = nationalBudget.EndYear
            });

            await FinancialApi.CreateAllocationAsync(new BudgetAllocationWriteDto
            {
                Name = $"{viewProposal.Purpose} — {entityName}",
                Allocated = viewProposal.Amount,
                Spent = 0,
                BudgetId = approvalBudgetId
            });

            await FinancialApi.ChangeProposalStatusAsync(viewProposal.ProposalId, new BudgetProposalStatusDto
            {
                Status = "Approved",
                ReviewedById = currentProfileId
            });

            nationalAllocatedMap[approvalBudgetId] = existingAllocated + viewProposal.Amount;
            await ReloadProposals();
            showViewModal = false; viewProposal = null; actionMode = ""; approvalBudgetId = 0;
        }
        catch (Exception ex) { approvalError = $"Approve failed: {ex.Message}"; }
        isActioning = false;
    }

    private async Task ExecuteAction()
    {
        if (viewProposal == null) return;
        if (string.IsNullOrWhiteSpace(actionReason)) { actionError = "Reason required."; return; }
        isActioning = true; actionError = "";
        try
        {
            await FinancialApi.ChangeProposalStatusAsync(viewProposal.ProposalId, new BudgetProposalStatusDto
            {
                Status = actionMode == "reject" ? "Disapproved" : "For Revision",
                ReviewedById = currentProfileId,
                RejectionReason = actionReason.Trim()
            });
            await ReloadProposals();
            showViewModal = false; viewProposal = null; actionMode = ""; actionReason = "";
        }
        catch (Exception ex) { actionError = $"Action failed: {ex.Message}"; }
        isActioning = false;
    }

    private List<BudgetProposalReadDto> approvalInbox => allProposals.Where(p => p.Status == "Pending" && (p.Level == "Local Church" || p.Level == "District")).ToList();

    private List<BudgetProposalReadDto> displayedProposals
    {
        get
        {
            var source = activeSubTab == "inbox" ? approvalInbox : allProposals.Where(p => p.Level != "Ministry").ToList();
            var q = source.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var s = searchQuery.Trim().ToLower();
                q = q.Where(p => p.Purpose.ToLower().Contains(s) || p.ProposalCode.ToLower().Contains(s));
            }
            if (!string.IsNullOrEmpty(statusFilter)) q = q.Where(p => p.Status == statusFilter);
            if (!string.IsNullOrEmpty(levelFilter)) q = q.Where(p => p.Level == levelFilter);
            return q.ToList();
        }
    }

    private int propPage = 1;
    private const int PropPageSize = 10;
    private List<BudgetProposalReadDto> pagedProposals => displayedProposals.Skip((propPage - 1) * PropPageSize).Take(PropPageSize).ToList();
    private int propTotalPages => Math.Max(1, (int)Math.Ceiling((double)displayedProposals.Count / PropPageSize));
}
