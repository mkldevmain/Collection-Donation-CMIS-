@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<nav class="site-navbar">
    <div class="navbar-inner">
        <a href="/home" class="navbar-brand" id="navbar-brand">
            <img src="images/jobmLogo.png" alt="Logo">
            <div class="brand-text">
                <span class="brand-title">JESUS OUR BANNER</span>
                <span class="brand-subtitle">MINISTRY</span>
            </div>
        </a>

        <button class="navbar-toggler" id="navbar-toggler" @onclick="ToggleMenu" aria-label="Toggle navigation">
            <span class="toggler-bar"></span>
            <span class="toggler-bar"></span>
            <span class="toggler-bar"></span>
        </button>

        <div class="navbar-links @(menuOpen ? "open" : "")">
            <a href="/home" class="nav-link" id="nav-home">HOME</a>
            <a href="/activities" class="nav-link" id="nav-activities">ACTIVITIES</a>
            <a href="/services" class="nav-link" id="nav-services">SERVICES</a>
            
            <div class="nav-dropdown" id="nav-ministries-dropdown">
                <button class="nav-link dropdown-toggle" @onclick="() => ToggleDropdown(1)">
                    MINISTRIES
                </button>
            </div>
            
            <div class="nav-dropdown" id="nav-about-dropdown">
                <button class="nav-link dropdown-toggle" @onclick="() => ToggleDropdown(2)">
                    ABOUT
                </button>
            </div>
            
            <a href="/give" class="nav-link" id="nav-give">GIVE</a>
        </div>
        
        <div class="auth-section">
            <AuthorizeView>
                <Authorized>
                    <div class="auth-divider"></div>
                    <img src="https://i.pravatar.cc/150?u=@(context.User.Identity?.Name ?? "default")" alt="User Profile" class="user-avatar" />
                </Authorized>
                <NotAuthorized>
                    <button class="joinbutton" style="font-family: 'Degular Display', sans-serif;">
                        <p>JOIN US</p>
                        <i class="fi fi-rr-arrow-small-right"></i>
                    </button>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div> @if (activeDropdown != null)
    {
        <div class="dropdown-overlay" @onclick="CloseDropdowns"></div>
    }

    @if (activeDropdown == 1)
    {
        <div class="mega-menu-panel">
            <p class="mega-menu-heading">CHURCH MINISTRIES</p>
            <div class="mega-menu-cards">
                <a href="/ministries/kids" class="mega-card">
                    <img src="https://images.pexels.com/photos/18482980/pexels-photo-18482980.jpeg" alt="Kid's Ministry" class="custom-transform" style="--normal-transform: scaleX(-1) scale(1.2); --hover-transform: scaleX(-1) scale(1.3);" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Kid's Ministry</span>
                </a>
                <a href="/ministries/youth" class="mega-card">
                    <img src="https://images.pexels.com/photos/18482959/pexels-photo-18482959.jpeg" alt="Youth's Ministry" class="custom-transform" style="--normal-transform: scale(1.6); --hover-transform: scale(1.7);"  />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Youth's Ministry</span>
                </a>
                <a href="/ministries/youth-pro" class="mega-card">
                    <img src="https://images.pexels.com/photos/19492453/pexels-photo-19492453.jpeg" alt="Youth Pro Ministry" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Youth Pro Ministry</span>
                </a>
                <a href="/ministries/mens" class="mega-card">
                    <img src="https://images.pexels.com/photos/30816557/pexels-photo-30816557.jpeg" alt="Men's Ministry" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Men's Ministry</span>
                </a>
                <a href="/ministries/womens" class="mega-card">
                    <img src="https://images.pexels.com/photos/19492454/pexels-photo-19492454.jpeg" alt="Women's Ministry" class="custom-transform" style="--normal-transform: scaleX(-1) scale(3); --hover-transform: scaleX(-1) scale(3.1);" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Women's Ministry</span>
                </a>
                <a href="/ministries/music" class="mega-card">
                    <img src="https://images.pexels.com/photos/3101522/pexels-photo-3101522.jpeg" alt="Music Ministry" class="custom-transform" style="--normal-transform: scale(1.6); --hover-transform: scale(1.7);" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Music Ministry</span>
                </a>
            </div>
        </div>
    }
    @if (activeDropdown == 2)
    {
        <div class="mega-menu-panel">
            <h4 class="mega-menu-heading">ABOUT THE CHURCH</h4>
            <div class="mega-menu-cards">
                <a href="/about/beliefs" class="mega-card">
                    <img src="https://images.pexels.com/photos/8468421/pexels-photo-8468421.jpeg" alt="Our Beliefs" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Our Beliefs</span>
                </a>
                <a href="/about/history" class="mega-card">
                    <img src="https://images.pexels.com/photos/2833037/pexels-photo-2833037.jpeg" alt="Our History" class="custom-transform" style="--normal-transform: scale(1.6) translateY(-20px); --hover-transform: scale(1.7) translateY(-20px);" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Our History</span>
                </a>
                <a href="/about/staff" class="mega-card">
                    <img src="https://images.pexels.com/photos/272337/pexels-photo-272337.jpeg" alt="Staff Directory" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Staff Directory</span>
                </a>
                <a href="/about/directory" class="mega-card">
                    <img src="https://images.pexels.com/photos/272337/pexels-photo-272337.jpeg" alt="Church Directory" />
                    <div class="mega-card-overlay"></div>
                    <span class="mega-card-label">Church Directory</span>
                </a>
            </div>
        </div>
    }
</nav> 
@code {
    private bool menuOpen = false;
    private int? activeDropdown = null;

    private void CloseDropdowns()
    {
        activeDropdown = null;
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        activeDropdown = null;
        menuOpen = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void ToggleMenu() => menuOpen = !menuOpen;

    private void ToggleDropdown(int id)
    {
        activeDropdown = activeDropdown == id ? null : id;
    }
}